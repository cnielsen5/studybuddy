{
  "name": "functions",
  "scripts": {
    "prebuild": "node -e \"const v=process.versions.node.split('.')[0]; if(v!=='20'){console.error('❌ Use Node 20 for functions. Current: Node ' + v + '. Run: nvm use 20'); process.exit(1)}\" && node scripts/copy-runtime-content.mjs && node scripts/bundle-library-creator.mjs",
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "predeploy": "node -e \"const v=process.versions.node.split('.')[0]; if(v!=='20'){console.error('❌ Use Node 20 for functions. Current: Node ' + v + '. Run: nvm use 20'); process.exit(1)}\"",
    "deploy": "firebase deploy --only functions",
    "deploy:all": "npm run build && firebase deploy",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "deploy:indexes": "firebase deploy --only firestore:indexes",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:staging": "npx firebase use staging && ./scripts/deploy.sh",
    "deploy:production": "npx firebase use production && ./scripts/deploy.sh",
    "logs": "firebase functions:log",
    "logs:follow": "firebase functions:log --follow",
    "test": "jest",
    "test:rules": "firebase emulators:exec --only firestore 'jest tests/integration/firestoreRules.integration.test.ts'",
    "test:rules:manual": "jest tests/integration/firestoreRules.integration.test.ts",
    "test:rules:programmatic": "jest tests/integration/securityRules.test.ts",
    "test:all": "npm test && npm run test:rules",
    "test:projection": "npm run build && npx tsc -p tsconfig.json && node lib/scripts/test-event-projection.js",
    "create-dev-user": "npm run build && npx tsc -p tsconfig.json && node lib/scripts/create-dev-user.js",
    "smoke:library-creation": "node scripts/smoke-library-creation-callable.mjs",
    "emulators:start": "firebase emulators:start --only firestore",
    "emulators:exec": "firebase emulators:exec --only firestore"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@google-cloud/firestore": "^8.0.0",
    "firebase-admin": "^13.6.0",
    "firebase-functions": "^7.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.4",
    "@jest/test-sequencer": "^30.2.0",
    "@types/handlebars": "^4.1.0",
    "@types/jest": "^30.0.0",
    "esbuild": "^0.25.12",
    "firebase-functions-test": "^3.4.1",
    "firebase-tools": "^13.35.1",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.7.3"
  },
  "private": true
}

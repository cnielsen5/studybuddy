{
  "name": "@studybuddy/library-creator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CLI pipeline for creating Socrates content libraries (Option B — app UI later)",
  "bin": {
    "library-creator": "./dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc",
    "cli": "tsx src/cli/main.ts",
    "build:spine": "tsx scripts/build-spine-graph.ts",
    "build:spine-review": "tsx scripts/build-spine-review.ts",
    "import:orthobullets": "tsx scripts/import-orthobullets-sheet.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "cheerio": "^1.0.0",
    "jsdom": "^26.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.10.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3"
  }
}

{
  "name": "@studybuddy/library-creator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CLI pipeline for creating Socrates content libraries (Option B — app UI later)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./dist/*": "./dist/*"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "library-creator": "./dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc",
    "cli": "tsx src/cli/main.ts",
    "build:spine": "tsx scripts/build-spine-graph.ts",
    "build:spine-review": "tsx scripts/build-spine-review.ts",
    "build:spine-l4-l5": "tsx scripts/build-spine-l4-l5.ts",
    "build:spine-l4-l5-review": "tsx scripts/build-spine-l4-l5-review.ts",
    "build:spine-l1-l5": "tsx scripts/build-spine-l1-l5.ts",
    "build:merge-proposals": "tsx scripts/build-merge-proposals-review.ts",
    "tag:merge-proposals": "tsx scripts/tag-merge-proposals.ts",
    "apply:merge-rules": "tsx scripts/apply-merge-rules.ts",
    "apply:context-rules": "tsx scripts/apply-context-rules.ts",
    "migrate:spine-l4-l5": "tsx scripts/migrate-spine-l4-l5.ts",
    "export:l4-l5-units": "tsx scripts/export-l4-l5-units.ts",
    "export:l4-l5-queue": "tsx scripts/export-l4-l5-generation-queue.ts",
    "check:spine-placement": "tsx scripts/check-spine-placement.ts",
    "validate:lenses": "tsx scripts/validate-lenses.ts",
    "build:orthopaedic-l2-l3": "tsx scripts/build-orthopaedic-l2-l3-draft.ts",
    "build:orthopaedic-l4-l5": "tsx scripts/build-orthopaedic-l4-l5-draft.ts",
    "consolidate:orthopaedic-spine": "tsx scripts/consolidate-orthopaedic-spine.ts",
    "pipeline:create": "tsx scripts/run-user-pipeline.ts",
    "import:orthobullets": "tsx scripts/import-orthobullets-sheet.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "cheerio": "^1.0.0",
    "jsdom": "^26.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.10.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3"
  }
}

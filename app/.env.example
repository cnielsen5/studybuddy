# Copy to .env.local and fill in from Firebase Console → Project settings → Your apps
# Project: socrates-staging-eedc4

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=socrates-staging-eedc4.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=socrates-staging-eedc4
VITE_FIREBASE_STORAGE_BUCKET=socrates-staging-eedc4.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Dev auth — user must exist in Firebase Auth with UID matching VITE_USER_ID
# Create via Admin SDK: uid must start with "user_" (e.g. user_dev_001)
VITE_DEV_EMAIL=dev@socrates.local
VITE_DEV_PASSWORD=

VITE_USER_ID=user_dev_001
VITE_LIBRARY_ID=lib_learning_science_v1
VITE_DEVICE_ID=web_dev_001

# Local Cloud Functions emulator (npm run serve in functions/)
VITE_USE_FUNCTIONS_EMULATOR=true

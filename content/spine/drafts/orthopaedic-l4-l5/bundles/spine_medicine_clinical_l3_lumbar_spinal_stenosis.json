      "id": "spine_medicine_clinical_l4_lumbar_spinal_stenosis_core_principles",
      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_clinical_l3_lumbar_spinal_stenosis",
      "content": {
        "title": "Lumbar Spinal Stenosis — Core Principles",
        "definition": "Narrowing of the lumbar spinal canal or neural foramina causing neurogenic claudication and radiculopathy in older adults.",
        "summary": "Neurogenic claudication improves with flexion (shopping cart sign). Decompression with or without fusion depends on spondylolisthesis and instability."
      },
      "knowledge_graph": {

      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_clinical_l3_extensor_mechanism_knee_injuries",
      "content": {
        "title": "Extensor Mechanism Knee Injuries — Core Principles",
        "definition": "Disruption of the quadriceps tendon, patellar tendon, or patella fracture compromising knee extension.",
        "summary": "Patellar tendon and quadriceps tears require operative repair. Bipartite patella mimics fracture. Stiffness and rerupture are complications."
      },
      "knowledge_graph": {

      "id": "spine_medicine_clinical_l4_compartment_syndrome_pathophysiology",
      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_clinical_l3_compartment_syndrome_and_fasciotomy",
      "content": {
        "title": "Compartment Syndrome Pathophysiology",
        "definition": "Elevated intracompartmental pressure reducing capillary perfusion below critical threshold.",
        "summary": "Ischemia-reperfusion causes irreversible muscle and nerve damage within hours."
      },

      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_clinical_l3_compartment_syndrome_and_fasciotomy",
      "content": {
        "title": "Compartment Pressure Measurement",
        "definition": "Intracompartmental pressure monitoring when clinical exam is unreliable (sedation, intubation, children).",
        "summary": "Delta pressure (diastolic BP minus compartment pressure) ≤30 mmHg indicates syndrome."
      },

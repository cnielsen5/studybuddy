    {
      "id": "spine_medicine_clinical_l4_compartment_syndrome_clinical_diagnosis",
      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_clinical_l3_compartment_syndrome_and_fasciotomy",
      "content": {
        "title": "Compartment Syndrome Clinical Diagnosis",
        "definition": "Pain out of proportion, pain with passive stretch, paresthesias, pallor, pulselessness, paralysis.",
        "summary": "Clinical diagnosis in awake patients; do not wait for compartment pressure if exam is convincing."
      },

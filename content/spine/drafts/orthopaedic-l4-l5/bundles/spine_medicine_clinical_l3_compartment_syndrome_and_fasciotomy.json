      "resolution_level": 5,
      "anchor_concept_id": "spine_medicine_clinical_l3_compartment_syndrome_and_fasciotomy",
      "content": {
        "title": "Volkmann Ischemic Contracture",
        "definition": "Fixed flexion deformity of forearm and hand after untreated forearm compartment syndrome.",
        "summary": "Prevention is emergent fasciotomy; late treatment includes tendon lengthening and free muscle transfer."
      },

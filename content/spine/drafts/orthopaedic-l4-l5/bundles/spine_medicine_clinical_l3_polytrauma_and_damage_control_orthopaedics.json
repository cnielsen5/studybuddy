      "content": {
        "title": "Definitive Fixation Timing",
        "definition": "Conversion from external fixation to IM nail or plate when lactate normalized and coagulopathy corrected.",
        "summary": "Window often 5–10 days; pin-site infection risk increases with prolonged external fixation."
      },

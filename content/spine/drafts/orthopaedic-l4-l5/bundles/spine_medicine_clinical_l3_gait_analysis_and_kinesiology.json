      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_clinical_l3_gait_analysis_and_kinesiology",
      "content": {
        "title": "Gait Analysis and Kinesiology — Core Principles",
        "definition": "Systematic study of human locomotion phases, joint kinematics, and kinetics during the gait cycle.",
        "summary": "Stance and swing phases divide gait. Hip, knee, and ankle moments peak at distinct phases. Pathologic gait patterns localize neuromuscular and structural deficits."
      },

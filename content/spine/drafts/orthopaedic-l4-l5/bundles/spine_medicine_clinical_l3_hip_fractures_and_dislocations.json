      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_clinical_l3_hip_fractures_and_dislocations",
      "content": {
        "title": "Traumatic Hip Dislocation",
        "definition": "Posterior and anterior hip dislocations requiring urgent closed reduction within six hours to protect femoral head.",
        "summary": "Sciatic nerve injury complicates posterior dislocation; post-reduction CT assesses acetabular and head injury."
      },

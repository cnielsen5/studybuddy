      "content": {
        "title": "Intertrochanteric and Subtrochanteric Fractures",
        "definition": "Extracapsular hip fractures managed with cephalomedullary nail or sliding hip screw.",
        "summary": "Reverse obliquity patterns need intramedullary fixation; subtrochanteric may need long cephalomedullary nail."
      },

      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_clinical_l3_general_paediatric_trauma",
      "content": {
        "title": "Paediatric Trauma Assessment",
        "definition": "Age-specific injury patterns, skeletal immaturity, and higher ligamentous-to-bone injury ratio in children.",
        "summary": "Children tolerate blood loss poorly; prioritize ATLS pediatric resuscitation before fracture fixation."
      },

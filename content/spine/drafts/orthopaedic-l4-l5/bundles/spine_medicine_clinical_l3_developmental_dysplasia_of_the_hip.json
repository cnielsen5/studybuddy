      "content": {
        "title": "DDH Pavlik Harness and Closed Reduction",
        "definition": "Dynamic flexion-abduction splinting in infants; closed reduction and spica cast if harness fails.",
        "summary": "Pavlik success highest under six months; monitor for avascular necrosis."
      },

      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_clinical_l3_developmental_dysplasia_of_the_hip",
      "content": {
        "title": "DDH Imaging",
        "definition": "Graf ultrasound before ossification; AP pelvis with Hilgenreiner and Perkin lines after.",
        "summary": "Acetabular index and Shenton line disruption indicate dysplasia."

      "id": "spine_medicine_clinical_l4_pilon_and_ankle_fractures_core_principles",
      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_clinical_l3_pilon_and_ankle_fractures",
      "content": {
        "title": "Pilon and Ankle Fractures — Core Principles",
        "definition": "Distal tibial plafond (pilon) fractures and malleolar ankle fractures disrupting the mortise and syndesmosis.",
        "summary": "Ankle fractures follow Lauge-Hansen and Weber classifications. Syndesmosis integrity determines fixation. Pilon fractures often require staged ORIF."
      },
      "knowledge_graph": {
        "knowledge_area": "Clinical Sciences",
        "knowledge_cluster": "Trauma",

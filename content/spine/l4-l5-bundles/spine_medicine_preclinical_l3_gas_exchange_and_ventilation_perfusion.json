    {
      "id": "spine_medicine_preclinical_l4_oxygen_dissolved_vs_bound",
      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_preclinical_l3_gas_exchange_and_ventilation_perfusion",
      "content": {
        "title": "Dissolved vs Hemoglobin-Bound Oxygen",
        "definition": "Oxygen exists in blood as a small dissolved fraction (determining PaO2) and a large hemoglobin-bound fraction (determining total O2 content and SaO2).",
        "summary": "PaO2 reflects dissolved O2; pulse oximetry estimates SaO2. Anemia reduces content despite normal PaO2."
      },

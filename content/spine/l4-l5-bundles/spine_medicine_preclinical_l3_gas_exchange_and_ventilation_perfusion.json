    {
      "id": "spine_medicine_preclinical_l5_refractory_hypoxemia_shunt",
      "resolution_level": 5,
      "anchor_concept_id": "spine_medicine_preclinical_l3_gas_exchange_and_ventilation_perfusion",
      "content": {
        "title": "Refractory Hypoxemia from Shunt",
        "definition": "Severe hypoxemia poorly responsive to supplemental oxygen when significant intrapulmonary or intracardiac shunt bypasses ventilated alveoli.",
        "summary": "Shunt physiology explains refractory hypoxemia in ARDS and severe pneumonia. PEEP recruits collapsed alveoli to reduce shunt."
      },

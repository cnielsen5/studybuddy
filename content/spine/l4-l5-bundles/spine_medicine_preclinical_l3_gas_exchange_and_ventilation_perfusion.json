    {
      "id": "spine_medicine_preclinical_l4_shunt_vs_dead_space",
      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_preclinical_l3_gas_exchange_and_ventilation_perfusion",
      "content": {
        "title": "Shunt vs Dead Space Physiology",
        "definition": "Shunt is perfusion without ventilation (V/Q = 0); dead space is ventilation without perfusion (V/Q = ∞); both cause abnormal gas exchange and hypoxemia or hypercapnia.",
        "summary": "True shunt does not correct fully with supplemental O2. Dead space increases PaCO2 when alveolar ventilation is insufficient."
      },
      "knowledge_graph": {

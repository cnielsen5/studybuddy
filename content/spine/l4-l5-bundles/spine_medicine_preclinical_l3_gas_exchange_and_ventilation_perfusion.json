      "resolution_level": 5,
      "anchor_concept_id": "spine_medicine_preclinical_l3_gas_exchange_and_ventilation_perfusion",
      "content": {
        "title": "Pulmonary Embolism V/Q Mismatch",
        "definition": "PE obstructs perfusion to ventilated lung units creating high V/Q (dead space-like) regions and increasing physiologic dead space with hypoxemia.",
        "summary": "Sudden dyspnea and hypoxemia with clear chest X-ray suggest PE. V/Q scan or CTPA confirms diagnosis."
      },

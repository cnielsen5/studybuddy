    {
      "id": "spine_medicine_preclinical_l4_alveolar_arterial_gradient",
      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_preclinical_l3_gas_exchange_and_ventilation_perfusion",
      "content": {
        "title": "Alveolar-Arterial (A-a) Oxygen Gradient",
        "definition": "Difference between alveolar and arterial PO2 reflecting efficiency of oxygen transfer; elevated in V/Q mismatch, shunt, and diffusion impairment.",
        "summary": "A-a gradient = PAO2 − PaO2. Normal gradient increases slightly with age. Calculation uses alveolar gas equation."
      },

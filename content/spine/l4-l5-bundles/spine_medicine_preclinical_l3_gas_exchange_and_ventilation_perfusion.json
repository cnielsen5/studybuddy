    {
      "id": "spine_medicine_preclinical_l4_alveolar_gas_exchange_diffusion",
      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_preclinical_l3_gas_exchange_and_ventilation_perfusion",
      "content": {
        "title": "Alveolar Gas Exchange by Diffusion",
        "definition": "Passive diffusion of O2 and CO2 across the thin alveolar-capillary membrane driven by partial pressure gradients between alveolar gas and pulmonary capillary blood.",
        "summary": "Diffusion is rapid due to large surface area and short diffusion distance. Impaired diffusion is a less common hypoxemia mechanism than V/Q mismatch."
      },

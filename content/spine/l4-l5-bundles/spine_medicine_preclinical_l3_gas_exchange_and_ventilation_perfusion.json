    {
      "id": "spine_medicine_preclinical_l4_ventilation_perfusion_ratio",
      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_preclinical_l3_gas_exchange_and_ventilation_perfusion",
      "content": {
        "title": "Ventilation-Perfusion (V/Q) Ratio",
        "definition": "Regional ratio of alveolar ventilation to pulmonary blood flow; ideal matching is approximately 0.8 at the lung apex in upright posture.",
        "summary": "V/Q mismatch is the most common cause of hypoxemia. Gravity creates regional V/Q heterogeneity in the upright lung."
      },

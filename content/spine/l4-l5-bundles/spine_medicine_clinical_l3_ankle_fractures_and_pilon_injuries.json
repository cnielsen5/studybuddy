      "content": {
        "title": "Pilon Fracture Staged Management",
        "definition": "External fixation and delayed ORIF for soft-tissue swelling before definitive plating.",
        "summary": "Blister and fracture-blister risk mandate staging; ORIF when wrinkle sign present."
      },

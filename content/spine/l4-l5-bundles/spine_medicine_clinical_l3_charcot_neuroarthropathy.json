      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_clinical_l3_charcot_neuroarthropathy",
      "content": {
        "title": "Charcot Clinical Diagnosis",
        "definition": "Warm, swollen, red foot with minimal pain and intact pulses distinguishing from cellulitis.",
        "summary": "Temperature difference >2°C versus contralateral foot supports Charcot."
      },

      "content": {
        "title": "Charcot Surgical Reconstruction",
        "definition": "Exostectomy, realignment osteotomy, and fusion for rocker-bottom deformity with ulcer.",
        "summary": "Surgery when quiescent stage; high complication and amputation risk."
      },

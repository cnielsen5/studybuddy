      "content": {
        "title": "Charcot Pathophysiology and Eichenholtz Stages",
        "definition": "Neuropathic bone and joint destruction in diabetes with acute fragmentation and coalescence phases.",
        "summary": "Acute stage: immobilize non-weight-bearing; misdiagnosis as infection is common."
      },

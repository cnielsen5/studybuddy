      "id": "spine_medicine_clinical_l4_charcot_nonoperative_management",
      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_clinical_l3_charcot_neuroarthropathy",
      "content": {
        "title": "Charcot Nonoperative Management",
        "definition": "Total contact cast and protected weight-bearing until consolidation.",
        "summary": "Cast changes weekly; may require months; lifelong depth-inlay shoes after."
      },

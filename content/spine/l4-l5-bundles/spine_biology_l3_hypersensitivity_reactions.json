    {
      "id": "spine_biology_l4_hypersensitivity_classification_overview",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_hypersensitivity_reactions",
      "content": {
        "title": "Gell and Coombs Classification Overview",
        "definition": "Framework categorizing excessive immune responses into four types by effector mechanism: IgE-mediated (I), cytotoxic antibody (II), immune complex (III), and delayed T-cell (IV).",
        "summary": "Type classification predicts timing, mediators, and clinical examples. Each type uses distinct adaptive immune effector pathways."
      },
      "knowledge_graph": {

    {
      "id": "spine_biology_l5_serum_sickness_mechanism",
      "resolution_level": 5,
      "anchor_concept_id": "spine_biology_l3_hypersensitivity_reactions",
      "content": {
        "title": "Serum Sickness Mechanism",
        "definition": "Type III reaction 1–2 weeks after foreign protein exposure when antigen–antibody complexes deposit in joints, kidneys, and vessels causing fever, rash, and arthralgia.",
        "summary": "Serum sickness follows antitoxin or drug-protein conjugate administration. Complement consumption and neutrophil infiltration drive symptoms."
      },

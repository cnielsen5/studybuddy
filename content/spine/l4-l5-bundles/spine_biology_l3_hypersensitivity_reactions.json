    {
      "id": "spine_biology_l4_hypersensitivity_type_iii",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_hypersensitivity_reactions",
      "content": {
        "title": "Type III Immune Complex Disease",
        "definition": "Tissue damage from deposition of antigen–antibody complexes in vessel walls and tissues, activating complement and recruiting inflammatory cells.",
        "summary": "Type III reactions cause serum sickness and Arthus reactions. Soluble immune complexes deposit in joints, kidneys, and skin, provoking inflammation."
      },

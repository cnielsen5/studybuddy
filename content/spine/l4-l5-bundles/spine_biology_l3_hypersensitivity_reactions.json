    {
      "id": "spine_biology_l4_hypersensitivity_type_ii",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_hypersensitivity_reactions",
      "content": {
        "title": "Type II Antibody-Mediated Cytotoxicity",
        "definition": "Hypersensitivity in which IgG or IgM antibodies bind cell-surface antigens, leading to complement-mediated lysis, opsonization, or antibody-dependent cellular cytotoxicity.",
        "summary": "Type II reactions destroy host cells bearing targeted antigens. Examples include hemolytic transfusion reactions and some drug-induced cytopenias."
      },

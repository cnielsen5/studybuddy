    {
      "id": "spine_biology_l4_hypersensitivity_type_iv",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_hypersensitivity_reactions",
      "content": {
        "title": "Type IV (Delayed T-Cell) Hypersensitivity",
        "definition": "T-cell-mediated tissue injury occurring 24–72 hours after antigen exposure, without antibody involvement, driven by sensitized CD4+ or CD8+ T cells.",
        "summary": "Delayed-type hypersensitivity involves macrophage activation and cytotoxic T-cell killing. PPD skin test and contact dermatitis are classic examples."
      },

      "resolution_level": 5,
      "anchor_concept_id": "spine_biology_l3_hypersensitivity_reactions",
      "content": {
        "title": "Anaphylaxis Mediators and Treatment",
        "definition": "Systemic type I reaction with rapid hypotension, bronchospasm, and urticaria mediated by histamine and leukotrienes; epinephrine is first-line treatment.",
        "summary": "Anaphylaxis requires immediate IM epinephrine. Antihistamines and steroids are adjunctive but do not replace epinephrine."
      },

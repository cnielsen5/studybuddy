      "id": "spine_biology_l5_ppd_tb_skin_test",
      "resolution_level": 5,
      "anchor_concept_id": "spine_biology_l3_hypersensitivity_reactions",
      "content": {
        "title": "PPD and TB Skin Test (Type IV)",
        "definition": "Delayed hypersensitivity reaction to tuberculin protein reflecting prior sensitization by Mycobacterium tuberculosis, read at 48–72 hours as induration.",
        "summary": "PPD tests cell-mediated immunity, not antibody. False negatives occur in immunosuppression; BCG can cause false positives."
      },

    {
      "id": "spine_biology_l5_autoimmune_hemolytic_anemia",
      "resolution_level": 5,
      "anchor_concept_id": "spine_biology_l3_hypersensitivity_reactions",
      "content": {
        "title": "Autoimmune Hemolytic Anemia (Type II)",
        "definition": "Warm or cold autoantibodies against RBC surface antigens causing extravascular or intravascular hemolysis as a type II hypersensitivity manifestation.",
        "summary": "Warm AIHA involves IgG against Rh antigens with splenic sequestration. Cold agglutinin disease involves IgM and complement."
      },

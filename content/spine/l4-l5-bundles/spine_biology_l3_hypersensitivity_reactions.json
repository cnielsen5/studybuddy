    {
      "id": "spine_biology_l4_hypersensitivity_type_i",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_hypersensitivity_reactions",
      "content": {
        "title": "Type I IgE-Mediated Hypersensitivity",
        "definition": "Immediate hypersensitivity mediated by IgE antibodies binding FcεRI on mast cells and basophils, triggering degranulation and allergic symptoms upon allergen re-exposure.",
        "summary": "Type I reactions include hay fever, asthma, and anaphylaxis. Sensitization produces allergen-specific IgE; subsequent exposure causes rapid mediator release."
      },
      "knowledge_graph": {

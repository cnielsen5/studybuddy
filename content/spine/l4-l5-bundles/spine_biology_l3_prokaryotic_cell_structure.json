    {
      "id": "spine_biology_l4_bacterial_ribosomes_antibiotic_targets",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_prokaryotic_cell_structure",
      "content": {
        "title": "Bacterial Ribosomes and Antibiotic Targets",
        "definition": "70S prokaryotic ribosomes (30S and 50S subunits) differing from 80S eukaryotic ribosomes, enabling selective inhibition by aminoglycosides, tetracyclines, macrolides, and chloramphenicol.",
        "summary": "Antibiotics exploit structural differences in ribosomal RNA and proteins. Misuse promotes resistance."
      },

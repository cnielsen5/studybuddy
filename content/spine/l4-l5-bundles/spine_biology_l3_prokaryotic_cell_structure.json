      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_prokaryotic_cell_structure",
      "content": {
        "title": "Prokaryotic vs Eukaryotic Organization",
        "definition": "Fundamental differences between prokaryotic cells lacking a nucleus and membrane-bound organelles and eukaryotic cells with compartmentalized organelles.",
        "summary": "Prokaryotes include bacteria and archaea. Their simpler architecture enables rapid growth and genetic exchange but limits compartmental specialization."
      },

    {
      "id": "spine_mathematics_l4_riemann_sums",
      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_definite_integrals",
      "content": {
        "title": "Riemann Sums and Area Approximation",
        "definition": "Approximations of signed area under a curve by summing f(xᵢ*)Δx over subintervals of a partition, with left, right, and midpoint variants.",
        "summary": "Riemann sums motivate the definite integral as a limit of better and better area approximations."
      },

    {
      "id": "spine_psychology_neuroscience_l4_phobia_social_anxiety",
      "resolution_level": 4,
      "anchor_concept_id": "spine_psychology_neuroscience_l3_anxiety_disorders",
      "content": {
        "title": "Specific Phobia and Social Anxiety Disorder",
        "definition": "Anxiety disorders defined by marked fear triggered by specific objects or situations (specific phobia) or by social or performance situations where scrutiny is possible (social anxiety disorder).",
        "summary": "Both disorders involve cue-triggered fear distinct from generalized worry. Avoidance or endurance with distress is central to diagnosis and drives exposure-based treatment selection."
      },

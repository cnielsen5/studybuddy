    {
      "id": "spine_psychology_neuroscience_l4_anxiety_first_line_pharmacotherapy",
      "resolution_level": 4,
      "anchor_concept_id": "spine_psychology_neuroscience_l3_anxiety_disorders",
      "content": {
        "title": "First-Line Pharmacotherapy for Anxiety",
        "definition": "Initial medication approaches for anxiety disorders, primarily selective serotonin reuptake inhibitors and serotonin-norepinephrine reuptake inhibitors, with buspirone for generalized anxiety and cautious short-term benzodiazepine use when indicated.",
        "summary": "SSRIs and SNRIs are first-line for most chronic anxiety disorders. Benzodiazepines provide rapid relief but carry dependence and cognitive risks and are not preferred for long-term monotherapy."
      },
      "knowledge_graph": {

    {
      "id": "spine_psychology_neuroscience_l4_anxiety_cbt_exposure_therapy",
      "resolution_level": 4,
      "anchor_concept_id": "spine_psychology_neuroscience_l3_anxiety_disorders",
      "content": {
        "title": "Psychotherapy for Anxiety (CBT and Exposure)",
        "definition": "Evidence-based psychological treatments for anxiety disorders using cognitive restructuring to modify catastrophic beliefs and graded exposure to reduce avoidance of feared stimuli.",
        "summary": "CBT addresses maladaptive cognitions and behavioral avoidance. Exposure therapy is particularly effective for phobias, panic, and social anxiety when hierarchies are constructed and practiced systematically."
      },

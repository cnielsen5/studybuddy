    {
      "id": "spine_psychology_neuroscience_l4_panic_disorder_agoraphobia",
      "resolution_level": 4,
      "anchor_concept_id": "spine_psychology_neuroscience_l3_anxiety_disorders",
      "content": {
        "title": "Panic Disorder and Agoraphobia",
        "definition": "Recurrent unexpected panic attacks followed by persistent concern about future attacks or maladaptive avoidance, with agoraphobia defined by fear of situations where escape or help may be difficult.",
        "summary": "Panic disorder centers on discrete surges of intense fear peaking within minutes. Agoraphobia may co-occur when patients avoid places associated with prior attacks or feared incapacitation."
      },
      "knowledge_graph": {

      "id": "spine_psychology_neuroscience_l4_generalized_anxiety_disorder",
      "resolution_level": 4,
      "anchor_concept_id": "spine_psychology_neuroscience_l3_anxiety_disorders",
      "content": {
        "title": "Generalized Anxiety Disorder Diagnosis",
        "definition": "A condition characterized by excessive, difficult-to-control worry about multiple domains occurring more days than not for at least six months, accompanied by associated somatic or cognitive symptoms.",
        "summary": "GAD is defined by persistent generalized worry rather than discrete panic episodes or specific phobic triggers. Diagnosis requires duration, functional impairment, and exclusion of attributable medical or substance causes."
      },

    {
      "id": "spine_psychology_neuroscience_l5_benzodiazepine_risks_anxiety",
      "resolution_level": 5,
      "anchor_concept_id": "spine_psychology_neuroscience_l3_anxiety_disorders",
      "content": {
        "title": "Benzodiazepine Risks and Dependence",
        "definition": "Adverse effects of benzodiazepine use including sedation, cognitive impairment, fall risk, tolerance, dependence, and withdrawal syndromes with prolonged or high-dose use.",
        "summary": "Benzodiazepines are effective for acute anxiety but carry significant long-term risks. They are generally avoided as monotherapy for chronic anxiety disorders."
      },

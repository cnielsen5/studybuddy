      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_first_order_odes",
      "content": {
        "title": "Linear First-Order ODEs",
        "definition": "Equations y′ + P(x)y = Q(x) solved by integrating factor μ(x) = e^{∫P(x)dx} multiplying both sides.",
        "summary": "The integrating factor method converts linear first-order ODEs to integrable total derivatives."
      },

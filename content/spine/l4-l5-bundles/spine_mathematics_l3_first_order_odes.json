      "anchor_concept_id": "spine_mathematics_l3_first_order_odes",
      "content": {
        "title": "Integrating Factor Method",
        "definition": "Procedure: compute μ, multiply ODE by μ, recognize (μy)′ = μQ, integrate to find y.",
        "summary": "Integrating factors extend beyond ODEs to exact equations and appear in standard form derivations."
      },

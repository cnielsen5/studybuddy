      "id": "spine_medicine_clinical_l4_factors_affecting_union",
      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_clinical_l3_fracture_healing_and_bone_remodeling_clinical",
      "content": {
        "title": "Factors Affecting Fracture Union",
        "definition": "Biologic and mechanical factors including nicotine, diabetes, NSAIDs, infection, and fixation stability.",
        "summary": "Smoking and NSAIDs impair union; unstable fixation causes delayed healing or nonunion."
      },

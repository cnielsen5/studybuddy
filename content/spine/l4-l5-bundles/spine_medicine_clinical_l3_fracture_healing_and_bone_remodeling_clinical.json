      "content": {
        "title": "Fracture Healing Phases",
        "definition": "Hematoma, inflammation, soft callus, hard callus, and remodeling phases of secondary bone healing.",
        "summary": "Primary healing requires rigid fixation; secondary healing proceeds through visible callus formation."
      },

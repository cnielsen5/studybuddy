      "content": {
        "title": "Nonunion and Delayed Union Management",
        "definition": "Hypertrophic versus atrophic nonunion biology and revision strategies including reaming, graft, and exchange nailing.",
        "summary": "Hypertrophic nonunion needs stability; atrophic nonunion needs biologic augmentation."
      },

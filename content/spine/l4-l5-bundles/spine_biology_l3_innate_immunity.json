    {
      "id": "spine_biology_l5_lps_tlr4_endotoxin",
      "resolution_level": 5,
      "anchor_concept_id": "spine_biology_l3_innate_immunity",
      "content": {
        "title": "LPS–TLR4–MD2 Complex (Endotoxin)",
        "definition": "Gram-negative lipopolysaccharide recognition by the TLR4–MD2–CD14 complex on innate cells triggering systemic inflammatory responses in endotoxemia.",
        "summary": "Endotoxin is the canonical TLR4 ligand driving septic shock physiology. LPS structure and lipid A moiety determine immunostimulatory potency."
      },
      "knowledge_graph": {
        "knowledge_area": "Clinical Sciences",

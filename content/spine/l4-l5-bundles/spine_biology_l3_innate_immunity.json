    {
      "id": "spine_biology_l4_complement_system",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_innate_immunity",
      "content": {
        "title": "Complement System",
        "definition": "Cascade of plasma proteins activated by classical, alternative, or lectin pathways to opsonize pathogens, recruit inflammatory cells, and form membrane attack complexes.",
        "summary": "Complement bridges innate recognition and effector functions. C3 convertase is the central amplification step; terminal components can lyse susceptible microbes."
      },

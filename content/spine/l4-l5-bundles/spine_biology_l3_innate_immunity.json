    {
      "id": "spine_biology_l4_inflammatory_mediators_innate",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_innate_immunity",
      "content": {
        "title": "Inflammatory Mediator Release",
        "definition": "Soluble mediators including cytokines, prostaglandins, bradykinin, and histamine that mediate vasodilation, permeability, pain, and leukocyte recruitment in acute inflammation.",
        "summary": "Innate activation produces a coordinated mediator profile causing cardinal signs of inflammation. Dysregulated release contributes to sepsis and tissue injury."
      },

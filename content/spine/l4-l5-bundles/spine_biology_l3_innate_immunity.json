    {
      "id": "spine_biology_l4_tlr_signaling_mydd88",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_innate_immunity",
      "content": {
        "title": "TLR Signaling and MyD88 Pathway",
        "definition": "Adaptor-dependent signaling downstream of Toll-like receptors, prominently through MyD88, leading to NF-κB and MAPK activation and pro-inflammatory cytokine transcription.",
        "summary": "MyD88-dependent TLR signaling drives rapid cytokine release in bacterial infection. Alternative adaptors mediate type I interferon responses for endosomal TLRs."
      },

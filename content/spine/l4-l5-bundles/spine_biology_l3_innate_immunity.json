    {
      "id": "spine_biology_l4_phagocytosis",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_innate_immunity",
      "content": {
        "title": "Phagocytosis and Opsonization",
        "definition": "Engulfment and destruction of pathogens by neutrophils and macrophages, enhanced when particles are coated with opsonins such as complement C3b or antibodies.",
        "summary": "Phagocytes internalize microbes into phagolysosomes for enzymatic killing. Opsonization marks pathogens for efficient recognition and uptake."
      },

    {
      "id": "spine_biology_l4_physical_barriers",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_innate_immunity",
      "content": {
        "title": "Physical and Anatomic Barriers",
        "definition": "First-line innate defenses including intact skin, mucous membranes, cilia, lysozyme, and low gastric pH that prevent pathogen entry.",
        "summary": "Physical barriers exclude most microbes before immune recognition occurs. Mucociliary clearance and chemical secretions provide additional non-specific protection."
      },

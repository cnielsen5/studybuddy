    {
      "id": "spine_biology_l4_pattern_recognition_receptors",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_innate_immunity",
      "content": {
        "title": "Pattern-Recognition Receptors",
        "definition": "Innate immune receptors detecting conserved pathogen-associated molecular patterns (PAMPs) and damage-associated molecular patterns (DAMPs) to initiate inflammatory responses.",
        "summary": "TLRs, NLRs, and RLRs distinguish self from non-self at the molecular level. PRR engagement triggers cytokine production and phagocyte activation."
      },

    {
      "id": "spine_biology_l4_inflammatory_response",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_innate_immunity",
      "content": {
        "title": "Inflammatory Response",
        "definition": "Local tissue response to injury or infection characterized by redness, heat, swelling, and pain mediated by cytokines, histamine, prostaglandins, and recruited leukocytes.",
        "summary": "Inflammation confines infection and initiates repair. Acute inflammation recruits neutrophils; chronic inflammation can cause tissue damage if unresolved."
      },

      "id": "spine_biology_l5_saltatory_conduction",
      "resolution_level": 5,
      "anchor_concept_id": "spine_biology_l3_action_potential",
      "content": {
        "title": "Saltatory Conduction in Myelinated Axons",
        "definition": "Rapid action potential propagation in myelinated axons where depolarization jumps between nodes of Ranvier, regenerating at each node while myelin insulates internodal segments.",
        "summary": "Saltatory conduction increases conduction velocity and metabolic efficiency. Demyelination disrupts this mechanism and slows or blocks signal transmission."
      },
      "knowledge_graph": {
        "knowledge_area": "Life Sciences",
        "knowledge_cluster": "Cell Signaling",

    {
      "id": "spine_biology_l4_signal_propagation",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_action_potential",
      "content": {
        "title": "Continuous and Saltatory Conduction",
        "definition": "Propagation of action potentials along unmyelinated axons by sequential depolarization of adjacent membrane regions, or along myelinated axons by jumping between nodes of Ranvier.",
        "summary": "Myelin increases conduction velocity by insulating internodal regions and concentrating current at nodes. Saltatory conduction is energetically efficient for long-distance signaling."
      },
      "knowledge_graph": {

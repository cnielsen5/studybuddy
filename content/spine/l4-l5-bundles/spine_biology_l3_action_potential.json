    {
      "id": "spine_biology_l4_local_anesthetic_na_blockade",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_action_potential",
      "content": {
        "title": "Local Anesthetic Mechanism (Na⁺ Channel Blockade)",
        "definition": "Use-dependent blockade of voltage-gated sodium channels by local anesthetic agents, preventing depolarization and action potential propagation in sensory neurons.",
        "summary": "Local anesthetics bind sodium channels from the intracellular side preferentially in open or inactivated states, blocking propagation in high-frequency firing fibers first."
      },
      "knowledge_graph": {

      "id": "spine_biology_l4_excitatory_inhibitory_synapses",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_synaptic_transmission",
      "content": {
        "title": "Excitatory vs Inhibitory Synapses",
        "definition": "Synaptic classification based on whether neurotransmitter–receptor binding depolarizes (excitatory) or hyperpolarizes (inhibitory) the postsynaptic membrane.",
        "summary": "Excitatory synapses bring membrane potential toward threshold; inhibitory synapses move it away. Neural circuits balance both to regulate output."
      },
      "knowledge_graph": {

    {
      "id": "spine_biology_l5_presynaptic_facilitation_depression",
      "resolution_level": 5,
      "anchor_concept_id": "spine_biology_l3_synaptic_transmission",
      "content": {
        "title": "Presynaptic Facilitation and Depression",
        "definition": "Short-term increases (facilitation) or decreases (depression) in neurotransmitter release probability following patterns of prior activity, driven by residual presynaptic calcium and vesicle pool depletion.",
        "summary": "Facilitation enhances release after brief bursts; depression follows sustained high-frequency firing. Together they filter synaptic gain over seconds and shape temporal coding."
      },
      "knowledge_graph": {

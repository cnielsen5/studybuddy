      "resolution_level": 5,
      "anchor_concept_id": "spine_biology_l3_synaptic_transmission",
      "content": {
        "title": "NMDA Receptor Coincidence Detection in LTP",
        "definition": "NMDA receptors require simultaneous glutamate binding and postsynaptic depolarization to relieve Mg2+ block and permit Ca2+ influx initiating LTP.",
        "summary": "Coincidence detection implements Hebbian learning: cells that fire together wire together."
      },

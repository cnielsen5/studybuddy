      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_synaptic_transmission",
      "content": {
        "title": "Synaptic Plasticity and LTP",
        "definition": "Activity-dependent strengthening of synaptic transmission, notably long-term potentiation (LTP), underlying learning and memory formation.",
        "summary": "NMDA receptor coincidence detection (glutamate + depolarization) triggers Ca2+-dependent strengthening. LTP increases AMPA receptor insertion."
      },

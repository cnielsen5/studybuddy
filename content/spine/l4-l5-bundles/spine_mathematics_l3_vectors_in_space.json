    {
      "id": "spine_mathematics_l4_dot_product",
      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_vectors_in_space",
      "content": {
        "title": "Dot Product",
        "definition": "For u = ⟨u₁, u₂, u₃⟩ and v = ⟨v₁, v₂, v₃⟩, u · v = u₁v₁ + u₂v₂ + u₃v₃ = |u||v|cos θ.",
        "summary": "The dot product measures alignment of vectors, yields projections, and tests orthogonality when u · v = 0."
      },

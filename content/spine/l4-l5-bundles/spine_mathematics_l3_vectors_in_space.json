      "id": "spine_mathematics_l4_cross_product",
      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_vectors_in_space",
      "content": {
        "title": "Cross Product",
        "definition": "u × v is a vector perpendicular to both u and v with magnitude |u||v|sin θ, computed via determinant formula in 3D.",
        "summary": "Cross products yield area of parallelograms, torque vectors, and surface normal directions."
      },

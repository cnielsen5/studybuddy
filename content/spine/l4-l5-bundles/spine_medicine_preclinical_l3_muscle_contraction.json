    {
      "id": "spine_medicine_preclinical_l4_sliding_filament_mechanism",
      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_preclinical_l3_muscle_contraction",
      "content": {
        "title": "Sliding Filament Mechanism",
        "definition": "Sarcomere shortening by actin thin filaments sliding over myosin thick filaments via cross-bridge cycling powered by ATP hydrolysis without shortening of filaments themselves.",
        "summary": "Cross-bridge cycling involves myosin head attachment, power stroke, detachment, and re-cocking. Titin provides passive elasticity."
      },

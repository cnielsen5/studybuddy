    {
      "id": "spine_medicine_preclinical_l4_excitation_contraction_coupling",
      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_preclinical_l3_muscle_contraction",
      "content": {
        "title": "Excitation-Contraction Coupling",
        "definition": "Link between sarcolemmal action potential and sarcoplasmic reticulum Ca2+ release via dihydropyridine–ryanodine receptor coupling at the T-tubule.",
        "summary": "AP spreads along T-tubules; DHP receptors trigger RyR opening; Ca2+ floods cytosol initiating contraction."
      },
      "knowledge_graph": {

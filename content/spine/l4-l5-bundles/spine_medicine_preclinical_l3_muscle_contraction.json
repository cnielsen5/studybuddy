      "id": "spine_medicine_preclinical_l5_lambert_eaton_nm_junction",
      "resolution_level": 5,
      "anchor_concept_id": "spine_medicine_preclinical_l3_muscle_contraction",
      "content": {
        "title": "Lambert-Eaton Myasthenic Syndrome",
        "definition": "Autoantibodies against presynaptic voltage-gated Ca2+ channels reducing ACh release, causing proximal weakness that improves with repeated use (opposite of myasthenia gravis).",
        "summary": "LEMS associates with small cell lung cancer. Repetitive stimulation increases Ca2+ influx and improves release."
      },

    {
      "id": "spine_medicine_preclinical_l4_tropomyosin_troponin_regulation",
      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_preclinical_l3_muscle_contraction",
      "content": {
        "title": "Tropomyosin-Troponin Calcium Regulation",
        "definition": "Thin-filament regulation in which Ca2+ binding to troponin C shifts tropomyosin exposing myosin-binding sites on actin to initiate cross-bridge cycling.",
        "summary": "At rest, tropomyosin blocks actin sites. Calcium is the essential trigger for skeletal and cardiac contraction."
      },

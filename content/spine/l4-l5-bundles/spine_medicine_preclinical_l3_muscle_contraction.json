    {
      "id": "spine_medicine_preclinical_l5_malignant_hyperthermia_ryr",
      "resolution_level": 5,
      "anchor_concept_id": "spine_medicine_preclinical_l3_muscle_contraction",
      "content": {
        "title": "Malignant Hyperthermia (RyR1)",
        "definition": "Autosomal dominant RyR1 mutation causing uncontrolled SR Ca2+ release upon volatile anesthetic or succinylcholine exposure, producing hypermetabolism and hyperthermia.",
        "summary": "Treatment is dantrolene, which blocks RyR-mediated Ca2+ release. Crisis requires immediate recognition."
      },

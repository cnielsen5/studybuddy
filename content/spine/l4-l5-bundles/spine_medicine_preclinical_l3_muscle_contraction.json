      "resolution_level": 5,
      "anchor_concept_id": "spine_medicine_preclinical_l3_muscle_contraction",
      "content": {
        "title": "Rigor Mortis and ATP Depletion",
        "definition": "Persistent actin-myosin cross-bridge binding after death when ATP is depleted, preventing myosin detachment and producing muscle rigidity.",
        "summary": "Rigor mortis onset reflects ATP loss. Resolution follows proteolytic degradation."
      },

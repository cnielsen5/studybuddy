    {
      "id": "spine_mathematics_l4_laws_of_exponents",
      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_exponential_functions",
      "content": {
        "title": "Laws of Exponents",
        "definition": "Rules b^m · b^n = b^{m+n}, (b^m)^n = b^{mn}, (ab)^n = a^n b^n, and b^0 = 1 governing algebraic manipulation of exponential expressions.",
        "summary": "Exponent laws simplify products, quotients, and powers of exponential terms before applying logarithms or calculus."
      },

    {
      "id": "spine_mathematics_l4_natural_base_e",
      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_exponential_functions",
      "content": {
        "title": "The Natural Base e",
        "definition": "The number e ≈ 2.71828 arising as lim_{n→∞}(1 + 1/n)ⁿ, base of the natural exponential f(x) = eˣ with slope equal to its value.",
        "summary": "e is the unique base where instantaneous rate of change equals the function value, central to calculus and continuous growth models."
      },

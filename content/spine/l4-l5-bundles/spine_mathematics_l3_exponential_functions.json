      "content": {
        "title": "Compound Interest and Continuous Growth",
        "definition": "Discrete compound interest A = P(1 + r/n)^{nt} and continuous growth A = Pe^{rt} model accumulating quantities over time.",
        "summary": "Financial and population growth applications motivate exponential functions and the transition from discrete to continuous compounding."
      },

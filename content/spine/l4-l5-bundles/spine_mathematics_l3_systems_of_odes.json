      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_systems_of_odes",
      "content": {
        "title": "Eigenvalue Method for Linear Systems",
        "definition": "Solutions built from eigenvectors v with eigenvalues λ: e^{λt}v forms fundamental solutions when eigenvalues are real and distinct.",
        "summary": "The eigenvalue method diagonalizes linear system dynamics into independent exponential modes."
      },

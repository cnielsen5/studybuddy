        {
          "domain_id": "biology",
          "framing": {
            "title_in_context": "Selective Membrane Permeability",
            "relevance": "Explains why resting potential is not zero.",
            "applications": [
              "K⁺ leak channels",
              "Relative permeability"
            ],
            "max_resolution_in_context": 4
          },
          "hierarchy_location": {
            "category": "Cell Biology",

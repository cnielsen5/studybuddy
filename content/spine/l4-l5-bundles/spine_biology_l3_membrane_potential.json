    {
      "id": "spine_biology_l4_equilibrium_vs_steady_state",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_membrane_potential",
      "content": {
        "title": "Equilibrium vs Steady-State Membrane Potential",
        "definition": "Resting potential is maintained by active transport despite passive ion leak.",
        "summary": "True equilibrium would require zero net flux for all ions simultaneously, which does not hold in living cells."
      },
      "knowledge_graph": {

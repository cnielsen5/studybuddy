      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_membrane_potential",
      "content": {
        "title": "Resting Membrane Potential",
        "definition": "Stable negative voltage across the membrane of unstimulated excitable cells, typically near −70 mV in neurons, maintained by ion gradients and selective permeability.",
        "summary": "Resting potential represents a steady state, not equilibrium. It provides the baseline from which depolarizing and hyperpolarizing signals are measured."
      },

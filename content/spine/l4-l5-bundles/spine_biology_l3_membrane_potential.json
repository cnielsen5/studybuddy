    {
      "id": "spine_biology_l4_selective_permeability",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_membrane_potential",
      "content": {
        "title": "Selective Membrane Permeability",
        "definition": "Differential ion flux across the membrane governed by leak channels and gated channels, with potassium permeability dominating at rest in most neurons.",
        "summary": "Membrane permeability determines which ions contribute most to membrane voltage. At rest, K⁺ leak channels keep the membrane near the potassium equilibrium potential."
      },
      "knowledge_graph": {
        "knowledge_area": "Life Sciences",
        "knowledge_cluster": "Electrical Signaling",
        "primary_domain": "biology",
        "_shared_concept_note": null
      },

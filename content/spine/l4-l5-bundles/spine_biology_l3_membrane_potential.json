      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_membrane_potential",
      "content": {
        "title": "Ion Concentration Gradients",
        "definition": "Unequal distribution of Na⁺, K⁺, Cl⁻, and other ions across the plasma membrane established by selective permeability and active transport.",
        "summary": "High intracellular K⁺ and low intracellular Na⁺ create chemical gradients that drive ion movement. These gradients store potential energy for electrical signaling."
      },

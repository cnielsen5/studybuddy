    {
      "id": "spine_biology_l4_goldman_hodgkin_katz_equation",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_membrane_potential",
      "content": {
        "title": "Goldman-Hodgkin-Katz Voltage Equation",
        "definition": "Extension of Nernst equation weighting multiple ion permeabilities to predict membrane potential when more than one ion is permeable simultaneously.",
        "summary": "GHK equation shows resting potential lies between individual equilibrium potentials, closer to the ion with highest relative permeability."
      },

      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_membrane_potential",
      "content": {
        "title": "Nernst Equilibrium Potential",
        "definition": "Membrane voltage at which the electrical driving force on an ion exactly balances its chemical gradient, calculated from intra- and extracellular concentrations.",
        "summary": "Each permeable ion contributes an equilibrium potential. The resting potential reflects weighted influence of multiple ions at partial permeability."
      },

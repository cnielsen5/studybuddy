    {
      "id": "spine_biology_l4_electrochemical_driving_force",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_membrane_potential",
      "content": {
        "title": "Electrochemical Driving Force on Ions",
        "definition": "Net force on an ion combining chemical and electrical gradients, determining direction and magnitude of ion flux when channels open.",
        "summary": "Driving force = Vm − Eion. Positive driving force on Na+ during rest drives inward current upon channel opening."
      },
      "knowledge_graph": {
        "knowledge_area": "Life Sciences",
        "knowledge_cluster": "Cell Signaling",
        "primary_domain": "biology",
        "_shared_concept_note": null

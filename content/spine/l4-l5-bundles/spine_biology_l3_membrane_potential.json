    {
      "id": "spine_biology_l4_electrochemical_gradient",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_membrane_potential",
      "content": {
        "title": "Electrochemical Gradient",
        "definition": "Combined electrical and chemical driving forces on an ion across the membrane, determining the direction and magnitude of passive ion flux.",
        "summary": "Ions move down their electrochemical gradients through open channels. The equilibrium potential is the voltage at which electrical and chemical forces balance for a given ion."
      },

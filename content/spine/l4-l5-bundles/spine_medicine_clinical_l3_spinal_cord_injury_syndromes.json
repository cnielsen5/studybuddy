      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_clinical_l3_spinal_cord_injury_syndromes",
      "content": {
        "title": "Autonomic Dysreflexia and Chronic SCI Complications",
        "definition": "Hypertensive crisis from noxious stimulus below T6 lesion; pressure injuries and spasticity.",
        "summary": "Remove stimulus first; sit patient up; nitroglycerin if severe."
      },

      "id": "spine_mathematics_l4_vector_field_definition",
      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_vector_fields",
      "content": {
        "title": "Vector Field Definition",
        "definition": "A vector field F assigns a vector F(x, y) or F(x, y, z) to each point in a domain, visualized as directed arrows.",
        "summary": "Vector fields represent velocity flows, gravitational forces, and electromagnetic fields."
      },

    {
      "id": "spine_mathematics_l4_gradient_fields",
      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_vector_fields",
      "content": {
        "title": "Gradient Fields and Potential Functions",
        "definition": "A field F is a gradient field if F = ∇f for some scalar potential f; such fields are conservative when domain is simply connected.",
        "summary": "Gradient fields connect scalar potentials to vector fields and enable path-independent line integrals."
      },

    {
      "id": "spine_mathematics_l4_divergence",
      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_vector_fields",
      "content": {
        "title": "Divergence of a Vector Field",
        "definition": "In 3D, div F = ∂P/∂x + ∂Q/∂y + ∂R/∂z measures net outflow per unit volume at a point.",
        "summary": "Positive divergence indicates source behavior; negative divergence indicates sink behavior in fluid flow models."
      },

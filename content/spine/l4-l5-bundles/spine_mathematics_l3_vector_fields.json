      "id": "spine_mathematics_l4_curl",
      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_vector_fields",
      "content": {
        "title": "Curl of a Vector Field",
        "definition": "Curl F = ∇ × F measures local rotation tendency of the field; zero curl in simply connected domains implies conservativity.",
        "summary": "Curl identifies rotational components in fluid and electromagnetic fields."
      },

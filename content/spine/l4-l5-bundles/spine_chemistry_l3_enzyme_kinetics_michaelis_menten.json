      "id": "spine_chemistry_l4_competitive_inhibition",
      "resolution_level": 4,
      "anchor_concept_id": "spine_chemistry_l3_enzyme_kinetics_michaelis_menten",
      "content": {
        "title": "Competitive Inhibition",
        "definition": "Inhibition in which an inhibitor competes with substrate for the active site, increasing apparent Km while leaving Vmax unchanged at high substrate concentrations.",
        "summary": "Competitive inhibitors resemble substrate structure. Excess substrate can overcome competitive inhibition, restoring Vmax."
      },

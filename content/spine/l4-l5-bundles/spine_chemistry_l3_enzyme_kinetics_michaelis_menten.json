    {
      "id": "spine_chemistry_l4_vmax_km_interpretation",
      "resolution_level": 4,
      "anchor_concept_id": "spine_chemistry_l3_enzyme_kinetics_michaelis_menten",
      "content": {
        "title": "Vmax and Km Interpretation",
        "definition": "Vmax is the maximal reaction velocity at saturating substrate concentration; Km is the substrate concentration at which velocity equals half Vmax, reflecting apparent affinity.",
        "summary": "Low Km indicates high substrate affinity. Vmax depends on enzyme concentration and catalytic turnover. Km is not a true dissociation constant but approximates it when catalysis is slow."
      },

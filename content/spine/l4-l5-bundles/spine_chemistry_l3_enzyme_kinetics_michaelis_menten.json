      "resolution_level": 4,
      "anchor_concept_id": "spine_chemistry_l3_enzyme_kinetics_michaelis_menten",
      "content": {
        "title": "Michaelis–Menten Equation",
        "definition": "Rate equation v = Vmax[S]/(Km + [S]) describing hyperbolic dependence of initial reaction velocity on substrate concentration for many enzymes.",
        "summary": "The Michaelis–Menten model assumes rapid equilibrium or steady-state formation of an enzyme–substrate complex. Velocity rises with [S] and asymptotically approaches Vmax."
      },

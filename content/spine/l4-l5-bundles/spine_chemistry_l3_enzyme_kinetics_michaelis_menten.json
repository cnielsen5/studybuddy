    {
      "id": "spine_chemistry_l4_km_and_substrate_affinity",
      "resolution_level": 4,
      "anchor_concept_id": "spine_chemistry_l3_enzyme_kinetics_michaelis_menten",
      "content": {
        "title": "Km and Substrate Affinity",
        "definition": "Michaelis constant Km as the substrate concentration at half-maximal velocity, inversely related to enzyme–substrate affinity when kcat is constant.",
        "summary": "Low Km indicates high affinity (less substrate needed for half Vmax). Km approximates the dissociation constant under simplifying assumptions."
      },

      "id": "spine_chemistry_l4_oxidative_phosphorylation_coupling",
      "resolution_level": 4,
      "anchor_concept_id": "spine_chemistry_l3_glycolysis_and_central_metabolism",
      "content": {
        "title": "Oxidative Phosphorylation and ATP Yield",
        "definition": "Electron transport chain oxidizing NADH and FADH2 with chemiosmotic proton gradient driving ATP synthase, yielding ~30–32 ATP per glucose oxidized completely.",
        "summary": "Oxidative phosphorylation is the major ATP source aerobically. Cyanide blocks complex IV, halting ATP production."
      },

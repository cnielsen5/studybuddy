      "resolution_level": 4,
      "anchor_concept_id": "spine_chemistry_l3_glycolysis_and_central_metabolism",
      "content": {
        "title": "TCA (Krebs) Cycle Overview",
        "definition": "Mitochondrial cyclic oxidation of acetyl-CoA generating NADH, FADH2, and GTP with release of CO2, serving as central hub connecting carbohydrates, fats, and proteins.",
        "summary": "Each acetyl-CoA turn produces 3 NADH, 1 FADH2, 1 GTP. TCA is aerobic and requires NAD+ regeneration via oxidative phosphorylation."
      },

      "resolution_level": 4,
      "anchor_concept_id": "spine_chemistry_l3_glycolysis_and_central_metabolism",
      "content": {
        "title": "Gluconeogenesis Overview",
        "definition": "Synthesis of glucose from non-carbohydrate precursors (lactate, glycerol, amino acids) using bypass reactions for irreversible glycolytic steps.",
        "summary": "Gluconeogenesis is essential during fasting. It shares seven glycolytic enzymes but uses distinct enzymes for the three irreversible steps."
      },

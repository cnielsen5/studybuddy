      "id": "spine_chemistry_l4_glycolysis_energy_payoff",
      "resolution_level": 4,
      "anchor_concept_id": "spine_chemistry_l3_glycolysis_and_central_metabolism",
      "content": {
        "title": "Glycolysis Energy Payoff Phase",
        "definition": "Later glycolytic steps generating four ATP and two NADH per glucose through substrate-level phosphorylation and glyceraldehyde-3-phosphate oxidation.",
        "summary": "The payoff phase yields a net gain of two ATP and two NADH per glucose. Pyruvate kinase catalyzes the final irreversible step."
      },

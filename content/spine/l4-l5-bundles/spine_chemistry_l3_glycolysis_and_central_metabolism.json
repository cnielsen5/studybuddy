      "resolution_level": 4,
      "anchor_concept_id": "spine_chemistry_l3_glycolysis_and_central_metabolism",
      "content": {
        "title": "Glycolysis Energy Investment Phase",
        "definition": "Initial steps of glycolysis consuming two ATP per glucose to phosphorylate and cleave hexose into two triose phosphate intermediates.",
        "summary": "Hexokinase and phosphofructokinase-1 catalyze irreversible, ATP-consuming steps. The investment phase prepares glucose for energy extraction."
      },

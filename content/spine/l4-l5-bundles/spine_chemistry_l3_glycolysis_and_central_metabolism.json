    {
      "id": "spine_chemistry_l4_pyruvate_fate_aerobic_anaerobic",
      "resolution_level": 4,
      "anchor_concept_id": "spine_chemistry_l3_glycolysis_and_central_metabolism",
      "content": {
        "title": "Pyruvate Fate: Aerobic vs Anaerobic",
        "definition": "Aerobic conditions route pyruvate to mitochondrial acetyl-CoA; anaerobic conditions reduce pyruvate to lactate regenerating NAD+ for glycolysis continuation.",
        "summary": "Lactate dehydrogenase reaction sustains glycolysis in hypoxic tissue. Aerobic pyruvate dehydrogenase links glycolysis to TCA cycle."
      },

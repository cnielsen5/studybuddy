      "id": "spine_chemistry_l4_fermentation_pathways",
      "resolution_level": 4,
      "anchor_concept_id": "spine_chemistry_l3_glycolysis_and_central_metabolism",
      "content": {
        "title": "Fermentation Pathways",
        "definition": "Anaerobic regeneration of NAD⁺ from NADH by reducing pyruvate to lactate or ethanol, allowing glycolysis to continue without oxidative phosphorylation.",
        "summary": "Fermentation recycles NAD⁺ so glycolysis can sustain ATP production under anaerobic conditions. Lactic acid fermentation occurs in muscle; alcoholic fermentation in yeast."
      },

      "content": {
        "title": "Warburg Effect (Aerobic Glycolysis)",
        "definition": "Cancer cells preferentially using glycolysis for ATP even in adequate oxygen, supporting biosynthetic precursor production for rapid proliferation.",
        "summary": "Warburg effect reflects altered PFK and mitochondrial regulation, not simply hypoxia. Provides target for metabolic therapy research."
      },

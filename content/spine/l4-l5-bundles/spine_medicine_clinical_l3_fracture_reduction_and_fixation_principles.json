    {
      "id": "spine_medicine_clinical_l4_reduction_techniques_open_and_closed",
      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_clinical_l3_fracture_reduction_and_fixation_principles",
      "content": {
        "title": "Reduction Techniques — Open and Closed",
        "definition": "Methods to restore length, alignment, and rotation including closed manipulation, traction, and open direct reduction.",
        "summary": "Malreduction in rotation or length causes functional deficit. Indirect reduction preserves soft-tissue attachments when possible."
      },

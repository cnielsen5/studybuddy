    {
      "id": "spine_mathematics_l4_logarithm_as_inverse",
      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_logarithmic_functions",
      "content": {
        "title": "Logarithm as Inverse of Exponential",
        "definition": "y = log_b(x) means b^y = x for b > 0, b ≠ 1; the logarithm is the exponent that produces x from base b.",
        "summary": "Logarithmic and exponential functions are inverses, interchanging exponent and output roles."
      },

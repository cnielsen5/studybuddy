      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_logarithmic_functions",
      "content": {
        "title": "Logarithmic Graphs and Transformations",
        "definition": "Graphs of y = log_b x with vertical asymptote x = 0, domain (0, ∞), and transformations y = a log_b(x − h) + k.",
        "summary": "Log graphs rise slowly, reflecting compressed scale for large multiplicative ranges such as pH and decibels."
      },

    {
      "id": "spine_mathematics_l4_logarithm_properties",
      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_logarithmic_functions",
      "content": {
        "title": "Properties of Logarithms",
        "definition": "Rules log_b(xy) = log_b x + log_b y, log_b(x/y) = log_b x − log_b y, and log_b(x^p) = p log_b x for valid arguments.",
        "summary": "Log properties convert products to sums and powers to products, essential for solving equations and differentiating log functions."
      },

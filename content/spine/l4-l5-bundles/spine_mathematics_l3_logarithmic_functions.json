      "id": "spine_mathematics_l4_change_of_base",
      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_logarithmic_functions",
      "content": {
        "title": "Change-of-Base Formula",
        "definition": "log_b x = (ln x)/(ln b), converting logarithms to any convenient base, typically e or 10.",
        "summary": "Change of base enables calculator evaluation of logs in arbitrary bases and appears in algorithm analysis."
      },

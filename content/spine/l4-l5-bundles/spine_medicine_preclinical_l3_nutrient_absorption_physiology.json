      "id": "spine_medicine_preclinical_l4_carbohydrate_digestion_absorption",
      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_preclinical_l3_nutrient_absorption_physiology",
      "content": {
        "title": "Carbohydrate Digestion and Absorption",
        "definition": "Enzymatic hydrolysis of starch and disaccharides to monosaccharides (glucose, galactose, fructose) absorbed via specific transporters in the small intestinal brush border.",
        "summary": "SGLT1 cotransports glucose and galactose with Na+. GLUT5 absorbs fructose. Lactase deficiency causes lactose intolerance."
      },

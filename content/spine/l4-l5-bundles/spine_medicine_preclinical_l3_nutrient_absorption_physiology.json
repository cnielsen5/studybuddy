      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_preclinical_l3_nutrient_absorption_physiology",
      "content": {
        "title": "Vitamin B12 and Intrinsic Factor",
        "definition": "Gastric parietal cell secretion of intrinsic factor binding dietary B12 for absorption via cubilin receptor in terminal ileum.",
        "summary": "B12 deficiency causes megaloblastic anemia and neurologic deficits. Pernicious anemia is autoimmune IF deficiency."
      },

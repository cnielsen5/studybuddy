    {
      "id": "spine_medicine_preclinical_l4_protein_digestion_absorption",
      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_preclinical_l3_nutrient_absorption_physiology",
      "content": {
        "title": "Protein Digestion and Absorption",
        "definition": "Gastric and pancreatic proteases cleaving proteins to di- and tripeptides and amino acids absorbed via PepT1 and amino acid transporters in enterocytes.",
        "summary": "Pepsin initiates in stomach; trypsin and chymotrypsin complete in duodenum. Absorbed amino acids enter portal circulation."
      },

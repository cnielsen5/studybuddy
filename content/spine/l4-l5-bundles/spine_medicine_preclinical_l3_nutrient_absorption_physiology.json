      "content": {
        "title": "Pernicious Anemia (Intrinsic Factor Deficiency)",
        "definition": "Autoimmune destruction of gastric parietal cells reducing intrinsic factor and B12 absorption, causing macrocytic anemia and subacute combined degeneration.",
        "summary": "Anti-parietal cell and anti-IF antibodies present. Requires lifelong B12 replacement."
      },

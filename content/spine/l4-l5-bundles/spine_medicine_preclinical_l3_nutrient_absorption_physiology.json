      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_preclinical_l3_nutrient_absorption_physiology",
      "content": {
        "title": "Lipid Digestion and Absorption",
        "definition": "Emulsification and lipase hydrolysis of triglycerides, micelle formation, enterocyte re-esterification, and chylomicron packaging for lymphatic transport.",
        "summary": "Bile salts form micelles delivering lipid digestion products to enterocytes. Chylomicrons bypass portal circulation via lacteals."
      },

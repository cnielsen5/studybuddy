      "id": "spine_medicine_preclinical_l4_iron_absorption_regulation",
      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_preclinical_l3_nutrient_absorption_physiology",
      "content": {
        "title": "Iron Absorption and Regulation",
        "definition": "Duodenal enterocyte uptake of non-heme iron via DMT1 and export through ferroportin, regulated by hepcidin controlling systemic iron balance.",
        "summary": "Hepcidin blocks ferroportin in iron overload. Iron deficiency increases absorption efficiency."
      },

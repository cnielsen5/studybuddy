      "id": "spine_mathematics_l4_clairaut_theorem",
      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_partial_derivatives",
      "content": {
        "title": "Clairaut's Theorem on Mixed Partials",
        "definition": "If f_{xy} and f_{yx} are continuous on an open disk, then f_{xy} = f_{yx} at each point.",
        "summary": "Equality of mixed partials simplifies computation and guarantees symmetric Hessian entries for optimization."
      },

      "id": "spine_mathematics_l4_partial_derivative_definition",
      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_partial_derivatives",
      "content": {
        "title": "Partial Derivative Definition",
        "definition": "∂f/∂x is the derivative of f with respect to x holding other variables fixed; computed by usual rules treating other variables as constants.",
        "summary": "Partial derivatives isolate sensitivity to one input while holding others constant."
      },

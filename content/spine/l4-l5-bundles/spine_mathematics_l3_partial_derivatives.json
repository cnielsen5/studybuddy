    {
      "id": "spine_mathematics_l4_multivariable_chain_rule",
      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_partial_derivatives",
      "content": {
        "title": "Multivariable Chain Rule",
        "definition": "If z = f(x, y) with x = g(t), y = h(t), then dz/dt = (∂f/∂x)(dx/dt) + (∂f/∂y)(dy/dt).",
        "summary": "The multivariable chain rule tracks total rate of change through composed dependencies."
      },

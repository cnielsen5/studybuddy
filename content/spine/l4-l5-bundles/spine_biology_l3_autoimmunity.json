    {
      "id": "spine_biology_l4_central_tolerance",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_autoimmunity",
      "content": {
        "title": "Central Tolerance",
        "definition": "Deletion or inactivation of self-reactive lymphocytes during development in primary lymphoid organs (thymus for T cells, bone marrow for B cells).",
        "summary": "Negative selection in the thymus eliminates most autoreactive T cells. B cell central tolerance removes self-reactive clones before they enter circulation."
      },

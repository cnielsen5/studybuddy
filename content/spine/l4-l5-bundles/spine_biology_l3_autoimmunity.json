    {
      "id": "spine_biology_l4_central_peripheral_tolerance",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_autoimmunity",
      "content": {
        "title": "Central and Peripheral Tolerance",
        "definition": "Mechanisms eliminating or inactivating self-reactive lymphocytes during development in primary lymphoid organs and in peripheral tissues through deletion, anergy, and regulatory T cells.",
        "summary": "Central tolerance removes strongly autoreactive clones in thymus and bone marrow. Peripheral tolerance restrains low-avidity or tissue-restricted autoreactivity."
      },
      "knowledge_graph": {

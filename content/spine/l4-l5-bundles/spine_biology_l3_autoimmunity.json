    {
      "id": "spine_biology_l4_self_tolerance",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_autoimmunity",
      "content": {
        "title": "Self-Tolerance Overview",
        "definition": "Mechanisms ensuring lymphocytes do not mount adaptive responses against host antigens, including deletion of self-reactive clones and suppression of autoreactive cells.",
        "summary": "Self-tolerance prevents autoimmunity under normal conditions. Failure at central or peripheral checkpoints permits immune attack on self tissues."
      },

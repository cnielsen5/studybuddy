    {
      "id": "spine_biology_l4_epitope_spreading",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_autoimmunity",
      "content": {
        "title": "Epitope Spreading",
        "definition": "Progressive broadening of the autoimmune response to additional self-epitopes beyond the initiating antigen during chronic inflammation.",
        "summary": "Initial tissue damage releases cryptic self-antigens. Spreading amplifies and diversifies autoreactivity, worsening disease course."
      },

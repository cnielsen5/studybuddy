      "anchor_concept_id": "spine_biology_l3_autoimmunity",
      "content": {
        "title": "Autoantibody Effector Mechanisms",
        "definition": "Pathogenic mechanisms of self-directed antibodies including type II cytotoxicity, immune complex deposition, and receptor stimulation or blockade.",
        "summary": "Autoantibodies cause disease through complement-mediated lysis, opsonization, immune complex inflammation, or functional receptor modulation."
      },

    {
      "id": "spine_biology_l4_molecular_mimicry",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_autoimmunity",
      "content": {
        "title": "Molecular Mimicry and Epitope Spreading",
        "definition": "Autoimmune triggers including pathogen antigens resembling self epitopes (molecular mimicry) and immune responses spreading from initial to additional self epitopes (epitope spreading).",
        "summary": "Molecular mimicry links infection to autoimmunity when cross-reactive antibodies attack host tissues. Epitope spreading broadens the autoimmune attack over time."
      },

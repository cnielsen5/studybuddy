      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_autoimmunity",
      "content": {
        "title": "Representative Autoimmune Diseases",
        "definition": "Organ-specific and systemic autoimmune conditions including type 1 diabetes, rheumatoid arthritis, and systemic lupus erythematosus arising from tolerance failure.",
        "summary": "Autoimmune diseases reflect which self antigens are targeted. Organ-specific diseases attack one tissue type; systemic diseases involve multiple organs and autoantibodies."
      },

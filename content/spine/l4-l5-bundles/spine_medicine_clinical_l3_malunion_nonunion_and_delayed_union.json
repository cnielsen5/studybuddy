      "id": "spine_medicine_clinical_l4_malunion_nonunion_and_delayed_union_core_principles",
      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_clinical_l3_malunion_nonunion_and_delayed_union",
      "content": {
        "title": "Malunion, Nonunion, and Delayed Union — Core Principles",
        "definition": "Failure of fracture healing with deformity (malunion), absence of healing (nonunion), or prolonged healing (delayed union).",
        "summary": "Hypertrophic nonunion may respond to stabilization; atrophic nonunion requires biologic augmentation. Malunion correction uses osteotomy."
      },
      "knowledge_graph": {

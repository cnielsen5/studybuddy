      "content": {
        "title": "Separable Equation Form",
        "definition": "ODEs writable as dy/dx = g(x)h(y) or M(x) dx + N(y) dy = 0, allowing variables on opposite sides.",
        "summary": "Separability is the simplest analytic technique for first-order ODEs and includes exponential growth/decay."
      },

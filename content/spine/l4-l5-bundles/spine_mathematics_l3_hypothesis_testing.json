    {
      "id": "spine_mathematics_l4_p_values",
      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_hypothesis_testing",
      "content": {
        "title": "P-Values and Decision Rules",
        "definition": "The p-value is the probability, assuming H₀ is true, of observing a test statistic at least as extreme as the sample result.",
        "summary": "Compare p-value to α: reject H₀ if p ≤ α; otherwise fail to reject. P-values quantify evidence strength against H₀."
      },
      "knowledge_graph": {

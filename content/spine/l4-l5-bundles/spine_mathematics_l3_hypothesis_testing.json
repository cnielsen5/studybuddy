      "resolution_level": 5,
      "anchor_concept_id": "spine_mathematics_l3_hypothesis_testing",
      "content": {
        "title": "t-Test Assumptions",
        "definition": "One-sample t-tests require independent observations, approximate normality (or large n by CLT), and random sampling from the target population.",
        "summary": "Violations of assumptions affect validity; robust alternatives exist for non-normal small samples."
      },

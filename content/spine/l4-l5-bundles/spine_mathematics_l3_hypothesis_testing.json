    {
      "id": "spine_mathematics_l5_interpreting_p_values",
      "resolution_level": 5,
      "anchor_concept_id": "spine_mathematics_l3_hypothesis_testing",
      "content": {
        "title": "Interpreting P-Values Correctly",
        "definition": "A p-value is not the probability that H₀ is true; it is the probability of the observed (or more extreme) data given H₀.",
        "summary": "Correct interpretation avoids the common inverse-probability fallacy in reporting statistical results."
      },
      "knowledge_graph": {
        "knowledge_area": "Quantitative Reasoning",

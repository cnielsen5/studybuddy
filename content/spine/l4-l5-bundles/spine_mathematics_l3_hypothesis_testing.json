      "id": "spine_mathematics_l5_one_vs_two_tailed_tests",
      "resolution_level": 5,
      "anchor_concept_id": "spine_mathematics_l3_hypothesis_testing",
      "content": {
        "title": "One-Tailed vs Two-Tailed Tests",
        "definition": "Two-tailed tests split α between both directions; one-tailed tests concentrate α in one direction when the alternative is directional.",
        "summary": "Tail choice must be pre-specified; one-tailed tests have greater power for directional hypotheses but cannot detect effects in the opposite direction."
      },

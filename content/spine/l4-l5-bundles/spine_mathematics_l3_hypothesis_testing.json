      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_hypothesis_testing",
      "content": {
        "title": "Chi-Square Goodness-of-Fit Test",
        "definition": "Test comparing observed category counts to expected counts under H₀ using χ² = Σ(O − E)²/E with df = k − 1.",
        "summary": "Goodness-of-fit tests whether sample data match a specified categorical distribution."
      },

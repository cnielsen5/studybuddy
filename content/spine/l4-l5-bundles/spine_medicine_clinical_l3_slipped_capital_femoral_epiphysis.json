      "content": {
        "title": "SCFE Classification and Presentation",
        "definition": "Stable versus unstable slip by ability to weight-bear; acute, chronic, and acute-on-chronic.",
        "summary": "Unstable slip has high AVN risk; urgent in-situ pinning."
      },

      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_clinical_l3_slipped_capital_femoral_epiphysis",
      "content": {
        "title": "SCFE Diagnosis",
        "definition": "Frog-leg lateral radiograph showing slip of femoral epiphysis relative to metaphysis.",
        "summary": "Klein line fails to intersect epiphysis on AP view; bilateral in 20–40%."
      },

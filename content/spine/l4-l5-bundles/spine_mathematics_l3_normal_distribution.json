      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_normal_distribution",
      "content": {
        "title": "Central Limit Theorem (Introduction)",
        "definition": "The sampling distribution of the sample mean approaches normal as sample size increases, regardless of population shape (under finite variance).",
        "summary": "The CLT justifies normal approximations for sample means and is the bridge from descriptive statistics to inference."
      },

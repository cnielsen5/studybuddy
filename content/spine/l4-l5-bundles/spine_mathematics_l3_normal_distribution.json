      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_normal_distribution",
      "content": {
        "title": "Empirical Rule (68–95–99.7)",
        "definition": "For normal data, approximately 68% fall within 1σ of μ, 95% within 2σ, and 99.7% within 3σ.",
        "summary": "The empirical rule provides quick probability estimates without tables for roughly normal datasets."
      },

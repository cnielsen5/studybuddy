    {
      "id": "spine_medicine_preclinical_l5_afferent_efferent_gfr",
      "resolution_level": 5,
      "anchor_concept_id": "spine_medicine_preclinical_l3_renal_filtration_and_gfr",
      "content": {
        "title": "Afferent vs Efferent Arteriolar Effects on GFR",
        "definition": "Differential effects of constriction or dilation of afferent versus efferent glomerular arterioles on glomerular capillary pressure and glomerular filtration rate.",
        "summary": "Afferent constriction lowers GFR; efferent constriction raises GFR initially by increasing glomerular pressure. Angiotensin II preferentially constricts the efferent arteriole."
      },

    {
      "id": "spine_medicine_preclinical_l5_creatinine_clearance_caveats",
      "resolution_level": 5,
      "anchor_concept_id": "spine_medicine_preclinical_l3_renal_filtration_and_gfr",
      "content": {
        "title": "Creatinine Clearance Limitations",
        "definition": "Sources of error in using serum creatinine and creatinine-based equations to estimate glomerular filtration rate, including tubular secretion, muscle mass variation, and non-GFR determinants of creatinine.",
        "summary": "Creatinine is not a perfect GFR marker because it is secreted by tubules and produced proportionally to muscle mass. eGFR equations correct some but not all of these limitations."
      },

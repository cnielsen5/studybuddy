    {
      "id": "spine_medicine_preclinical_l4_filtration_fraction",
      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_preclinical_l3_renal_filtration_and_gfr",
      "content": {
        "title": "Renal Blood Flow and Filtration Fraction",
        "definition": "Filtration fraction is the ratio of glomerular filtration rate to renal plasma flow, expressing the fraction of plasma passing through the glomerulus that is filtered.",
        "summary": "Normal filtration fraction is about 20%. Changes in GFR or renal plasma flow alter FF independently, reflecting afferent/efferent tone and hemodynamic status."
      },
      "knowledge_graph": {

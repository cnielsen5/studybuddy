    {
      "id": "spine_medicine_preclinical_l4_glomerular_starling_forces",
      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_preclinical_l3_renal_filtration_and_gfr",
      "content": {
        "title": "Starling Forces Across the Glomerulus",
        "definition": "The balance of hydrostatic and oncotic pressures across the glomerular capillary wall that drives ultrafiltration of plasma into Bowman's space.",
        "summary": "Net filtration pressure is the sum of favoring and opposing forces across the capillary. Changes in afferent or efferent tone, plasma oncotic pressure, or Bowman's space pressure alter GFR."
      },

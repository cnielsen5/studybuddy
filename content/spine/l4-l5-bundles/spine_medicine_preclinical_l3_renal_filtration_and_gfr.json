    {
      "id": "spine_medicine_preclinical_l4_gfr_autoregulation",
      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_preclinical_l3_renal_filtration_and_gfr",
      "content": {
        "title": "Autoregulation of GFR (Myogenic and TGF)",
        "definition": "Intrinsic renal mechanisms that maintain relatively stable glomerular filtration rate across a range of systemic arterial pressures through myogenic arteriolar responses and tubuloglomerular feedback.",
        "summary": "Autoregulation protects GFR when blood pressure fluctuates within normal limits. Myogenic constriction of afferent arterioles and macula densa-mediated feedback adjust resistance to stabilize filtration."
      },

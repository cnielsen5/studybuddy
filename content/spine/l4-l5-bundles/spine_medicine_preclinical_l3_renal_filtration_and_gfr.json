    {
      "id": "spine_medicine_preclinical_l4_glomerular_filtration_barrier",
      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_preclinical_l3_renal_filtration_and_gfr",
      "content": {
        "title": "Glomerular Filtration Barrier",
        "definition": "A selective filter composed of fenestrated capillary endothelium, glomerular basement membrane, and podocyte foot processes that permits water and small solutes to pass while restricting large proteins and cells.",
        "summary": "The filtration barrier determines what enters the glomerular filtrate. Damage to podocytes or the basement membrane increases protein permeability and reduces selectivity."
      },

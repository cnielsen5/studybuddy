    {
      "id": "spine_medicine_preclinical_l4_gfr_measurement_estimation",
      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_preclinical_l3_renal_filtration_and_gfr",
      "content": {
        "title": "GFR Measurement and Estimation",
        "definition": "Quantification of glomerular filtration rate using clearance of an ideal filtration marker such as inulin, or estimation from serum creatinine-based equations in clinical practice.",
        "summary": "Inulin clearance is the gold standard for GFR. Creatinine-based eGFR equations provide practical estimates but carry assumptions and limitations that affect interpretation."
      },

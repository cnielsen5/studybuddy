    {
      "id": "spine_medicine_preclinical_l5_net_filtration_pressure",
      "resolution_level": 5,
      "anchor_concept_id": "spine_medicine_preclinical_l3_renal_filtration_and_gfr",
      "content": {
        "title": "Net Filtration Pressure Equation",
        "definition": "The algebraic sum of glomerular capillary hydrostatic pressure, Bowman's capsule hydrostatic pressure, and glomerular oncotic pressure that determines the driving force for ultrafiltration.",
        "summary": "Net filtration pressure = PGC − PBS − πGC. Each term's direction and typical magnitude are high-yield for understanding GFR changes."
      },

    {
      "id": "spine_mathematics_l4_net_change_theorem",
      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_fundamental_theorem_of_calculus",
      "content": {
        "title": "Net Change Theorem",
        "definition": "The integral of a rate of change over an interval equals the net change in the original quantity: ∫_a^b F′(x) dx = F(b) − F(a).",
        "summary": "Net change interprets integration physically: integrating velocity gives displacement; integrating marginal cost gives total cost change."
      },

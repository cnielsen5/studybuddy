    {
      "id": "spine_mathematics_l4_ftc_part2",
      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_fundamental_theorem_of_calculus",
      "content": {
        "title": "Fundamental Theorem of Calculus Part 2",
        "definition": "If f is continuous on [a, b] and F is any antiderivative of f, then ∫_a^b f(x) dx = F(b) − F(a).",
        "summary": "Part 2 enables evaluation of definite integrals via antiderivatives, completing the link between rates and totals."
      },

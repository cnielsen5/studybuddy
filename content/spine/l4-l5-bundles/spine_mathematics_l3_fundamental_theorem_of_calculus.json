    {
      "id": "spine_mathematics_l4_ftc_part1",
      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_fundamental_theorem_of_calculus",
      "content": {
        "title": "Fundamental Theorem of Calculus Part 1",
        "definition": "If f is continuous on [a, b] and F(x) = ∫_a^x f(t) dt, then F′(x) = f(x) for x in (a, b).",
        "summary": "Part 1 shows differentiation undoes integration: the rate of change of accumulated area equals the integrand."
      },

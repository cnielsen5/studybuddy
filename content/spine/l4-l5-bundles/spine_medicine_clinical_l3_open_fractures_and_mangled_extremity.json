      "content": {
        "title": "Open Fracture Initial Management",
        "definition": "Emergency assessment, tetanus prophylaxis, culture-directed antibiotics, and sterile dressing for open fractures.",
        "summary": "Early IV antibiotics within one hour reduce infection; avoid repeated wound probing in the field."
      },

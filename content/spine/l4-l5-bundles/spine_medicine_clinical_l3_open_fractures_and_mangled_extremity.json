      "content": {
        "title": "Mangled Extremity Severity Score (MESS)",
        "definition": "Scoring system combining injury energy, limb ischemia, shock, and age to aid salvage versus amputation decisions.",
        "summary": "MESS ≥7 suggests amputation may be appropriate; clinical judgment and patient preference remain paramount."
      },

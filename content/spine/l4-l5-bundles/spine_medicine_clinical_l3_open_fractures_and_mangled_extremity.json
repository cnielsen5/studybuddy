      "content": {
        "title": "Gustilo Classification and Antibiotic Protocols",
        "definition": "Grading open fractures and selecting antibiotic duration and coverage based on wound severity.",
        "summary": "First-generation cephalosporin is standard; add aminoglycoside for type III; penicillin for farm injuries."
      },

      "id": "spine_medicine_clinical_l4_fatigue_vs_insufficiency_fractures",
      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_clinical_l3_stress_fractures_and_insufficiency_fractures",
      "content": {
        "title": "Fatigue vs Insufficiency Fractures",
        "definition": "Fatigue fractures result from repetitive loading on normal bone; insufficiency fractures occur in abnormal or osteoporotic bone under normal stress.",
        "summary": "Mechanism distinction guides workup for underlying bone disease versus training load modification."
      },
      "knowledge_graph": {
        "knowledge_area": "Clinical Sciences",
        "knowledge_cluster": "Trauma",
        "primary_domain": "medicine_clinical",

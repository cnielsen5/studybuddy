    {
      "id": "spine_medicine_preclinical_l4_frank_starling_mechanism",
      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_preclinical_l3_cardiac_physiology",
      "content": {
        "title": "Frank-Starling Mechanism",
        "definition": "Intrinsic ability of the heart to increase stroke volume in response to increased venous return and end-diastolic fiber stretch up to a physiologic limit.",
        "summary": "Greater stretch produces stronger contraction via optimal actin-myosin overlap. Beyond the limit, output plateaus then declines."
      },

    {
      "id": "spine_medicine_preclinical_l4_cardiac_output_determinants",
      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_preclinical_l3_cardiac_physiology",
      "content": {
        "title": "Cardiac Output Determinants",
        "definition": "Cardiac output (CO = HR × SV) determined by heart rate, preload, afterload, and contractility, modulated by autonomic and hormonal influences.",
        "summary": "Sympathetic stimulation increases HR and contractility. CO adapts to metabolic demand during exercise."
      },

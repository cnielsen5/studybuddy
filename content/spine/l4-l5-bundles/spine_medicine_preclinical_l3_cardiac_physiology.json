      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_preclinical_l3_cardiac_physiology",
      "content": {
        "title": "Cardiac Cycle Phases",
        "definition": "Sequence of systole (isovolumetric contraction, ejection) and diastole (isovolumetric relaxation, filling) governing valve opening and pressure-volume relationships.",
        "summary": "Understanding the cardiac cycle links heart sounds, murmurs, and pressure tracings to mechanical events."
      },

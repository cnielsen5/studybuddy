      "id": "spine_medicine_preclinical_l5_baroreceptor_reflex_cardiac",
      "resolution_level": 5,
      "anchor_concept_id": "spine_medicine_preclinical_l3_cardiac_physiology",
      "content": {
        "title": "Baroreceptor Reflex and Cardiac Output",
        "definition": "Negative feedback via carotid and aortic baroreceptors adjusting heart rate and vascular tone to maintain arterial blood pressure.",
        "summary": "Hypotension triggers sympathetic increase in HR and contractility. Hypertension activates parasympathetic slowing."
      },

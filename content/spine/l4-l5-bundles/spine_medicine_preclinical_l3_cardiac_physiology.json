    {
      "id": "spine_medicine_preclinical_l4_preload_afterload_concepts",
      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_preclinical_l3_cardiac_physiology",
      "content": {
        "title": "Preload and Afterload",
        "definition": "Preload is ventricular end-diastolic volume (stretch); afterload is resistance the ventricle must overcome to eject blood, primarily aortic pressure for the left ventricle.",
        "summary": "Frank-Starling mechanism links preload to stroke volume. Afterload reduction improves output in heart failure."
      },

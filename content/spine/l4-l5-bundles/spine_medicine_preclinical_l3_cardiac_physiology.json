      "id": "spine_medicine_preclinical_l5_starling_curve_failure",
      "resolution_level": 5,
      "anchor_concept_id": "spine_medicine_preclinical_l3_cardiac_physiology",
      "content": {
        "title": "Starling Curve in Heart Failure",
        "definition": "Shift of the Frank-Starling curve downward and flattening in systolic heart failure, reducing stroke volume at any given preload.",
        "summary": "Compensatory fluid retention initially supports preload but eventually worsens congestion without improving output."
      },

      "content": {
        "title": "Reference Angles",
        "definition": "The acute angle between the terminal side of θ and the x-axis, used to evaluate trig functions in any quadrant by sign adjustment.",
        "summary": "Reference angles reduce trigonometric evaluation to first-quadrant values while preserving correct signs."
      },

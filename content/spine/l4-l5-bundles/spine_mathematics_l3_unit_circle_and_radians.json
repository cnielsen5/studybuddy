      "content": {
        "title": "Degree–Radian Conversion",
        "definition": "Radians measure arc length per unit radius; 180° = π radians, so θ radians = (π/180) × degrees.",
        "summary": "Calculus requires radian measure for correct derivative formulas of trigonometric functions."
      },

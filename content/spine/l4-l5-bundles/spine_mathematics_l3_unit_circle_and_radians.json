      "content": {
        "title": "Trigonometric Periodicity",
        "definition": "Sine and cosine have period 2π; tangent has period π, reflecting repeating values as θ advances around the circle.",
        "summary": "Periodicity explains oscillatory behavior in models of waves, seasons, and circular motion."
      },

      "content": {
        "title": "ACL Graft Selection",
        "definition": "Bone-patellar tendon-bone, hamstring, and quadriceps autograft versus allograft.",
        "summary": "BTB higher anterior knee pain; hamstring preserves extensor mechanism; allograft in revision/low demand."

      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_clinical_l3_anterior_cruciate_ligament_injury",
      "content": {
        "title": "ACL Injury Mechanism and Examination",
        "definition": "Pivot-shift, Lachman, and anterior drawer tests with hemarthrosis after acute injury.",
        "summary": "Non-contact pivot common in sports; concurrent meniscus and MCL injury frequent."
      },

      "id": "spine_mathematics_l4_path_independence",
      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_line_integrals",
      "content": {
        "title": "Path Independence and Conservative Fields",
        "definition": "A line integral is path-independent if it depends only on endpoints; equivalent to F being a gradient field on a simply connected domain.",
        "summary": "Conservative fields simplify work calculations to potential difference: ∫_C F·dr = f(B) − f(A)."
      },

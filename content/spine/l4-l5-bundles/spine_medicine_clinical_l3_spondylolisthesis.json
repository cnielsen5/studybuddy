      "resolution_level": 4,
      "anchor_concept_id": "spine_medicine_clinical_l3_spondylolisthesis",
      "content": {
        "title": "Spondylolisthesis — Core Principles",
        "definition": "Anterior slippage of one vertebral body on another from isthmic, degenerative, or traumatic causes.",
        "summary": "Isthmic spondylolisthesis affects young athletes; degenerative affects older adults. High-grade slips may require fusion with reduction."
      },
      "knowledge_graph": {

    {
      "id": "spine_biology_l4_active_immunization_principle",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_vaccination_principles",
      "content": {
        "title": "Active Immunization Principle",
        "definition": "Deliberate antigen exposure inducing adaptive immune memory without causing significant disease, priming B and T cells for rapid recall upon natural exposure.",
        "summary": "Active immunization generates endogenous immunity. Booster doses enhance memory magnitude and affinity."
      },
      "knowledge_graph": {

      "id": "spine_biology_l4_passive_immunization",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_vaccination_principles",
      "content": {
        "title": "Passive Immunization",
        "definition": "Administration of pre-formed antibodies (immune globulins or antitoxins) providing immediate but temporary protection without generating host memory.",
        "summary": "Passive immunization is used for post-exposure prophylaxis and toxin neutralization. Protection wanes as administered antibodies are degraded."
      },

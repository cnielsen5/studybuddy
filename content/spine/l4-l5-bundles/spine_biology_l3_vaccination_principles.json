    {
      "id": "spine_biology_l4_live_attenuated_vs_inactivated",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_vaccination_principles",
      "content": {
        "title": "Live Attenuated vs Inactivated Vaccines",
        "definition": "Live attenuated vaccines use weakened pathogens replicating to mimic natural infection; inactivated vaccines use killed organisms or fractions unable to replicate.",
        "summary": "Live vaccines generally produce stronger, longer-lasting immunity but carry contraindications in immunocompromised hosts. Inactivated vaccines often require adjuvants and boosters."
      },
      "knowledge_graph": {

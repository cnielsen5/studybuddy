      "id": "spine_biology_l4_booster_immunization",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_vaccination_principles",
      "content": {
        "title": "Booster Immunization",
        "definition": "Additional vaccine doses administered after the primary series to maintain or enhance immunologic memory and protective antibody levels.",
        "summary": "Boosters exploit secondary immune responses for rapid, high-titer antibody production. They are essential when primary responses wane or when facing variant antigens."
      },

      "content": {
        "title": "Gustilo-Anderson Open Fracture Grading",
        "definition": "Soft-tissue injury grading for open fractures predicting infection risk and guiding antibiotic duration.",
        "summary": "Type IIIB requires soft-tissue coverage; type IIIC includes arterial injury requiring repair."
      },

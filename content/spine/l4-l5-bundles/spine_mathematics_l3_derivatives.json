      "id": "spine_mathematics_l4_product_quotient_rules",
      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_derivatives",
      "content": {
        "title": "Product and Quotient Rules",
        "definition": "Rules for differentiating products (uv)′ = u′v + uv′ and quotients (u/v)′ = (u′v − uv′)/v² of differentiable functions.",
        "summary": "When functions are multiplied or divided rather than added, the product and quotient rules extend basic rules to composite algebraic forms."
      },

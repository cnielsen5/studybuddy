    {
      "id": "spine_mathematics_l4_chain_rule",
      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_derivatives",
      "content": {
        "title": "Chain Rule",
        "definition": "If y = f(g(x)), then dy/dx = f′(g(x)) · g′(x), giving the derivative of a composition as the product of the outer and inner derivatives.",
        "summary": "The chain rule handles nested functions and is essential for implicit differentiation, related rates, and transcendental derivatives."
      },

    {
      "id": "spine_mathematics_l4_intermediate_value_theorem",
      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_limits_and_continuity",
      "content": {
        "title": "Intermediate Value Theorem",
        "definition": "If f is continuous on [a, b] and N is any value between f(a) and f(b), then there exists c in (a, b) with f(c) = N.",
        "summary": "The IVT guarantees that continuous functions take every intermediate value, enabling root-finding arguments and existence proofs."
      },

    {
      "id": "spine_mathematics_l4_one_sided_limits",
      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_limits_and_continuity",
      "content": {
        "title": "One-Sided Limits",
        "definition": "Left-hand limit (x → a⁻) and right-hand limit (x → a⁺) describe approach from one side; the two-sided limit exists only when both one-sided limits agree.",
        "summary": "One-sided limits resolve piecewise behavior and are essential for defining continuity at endpoints and analyzing jump discontinuities."
      },

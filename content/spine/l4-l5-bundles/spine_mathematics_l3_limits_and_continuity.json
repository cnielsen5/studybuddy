    {
      "id": "spine_mathematics_l4_limit_definition",
      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_limits_and_continuity",
      "content": {
        "title": "Limit Definition and Notation",
        "definition": "The limit of f(x) as x approaches a is L if f(x) can be made arbitrarily close to L by taking x sufficiently close to a (but not equal to a).",
        "summary": "Limits describe intended output value as input approaches a point, even when the function is undefined or discontinuous at that point."
      },

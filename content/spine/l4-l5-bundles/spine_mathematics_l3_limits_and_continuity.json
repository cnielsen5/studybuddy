    {
      "id": "spine_mathematics_l4_limits_at_infinity",
      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_limits_and_continuity",
      "content": {
        "title": "Limits at Infinity and Horizontal Asymptotes",
        "definition": "Limits as x → ±∞ describe end behavior of functions; horizontal asymptotes occur at y = L when lim_{x→±∞} f(x) = L.",
        "summary": "End-behavior limits classify long-term growth or decay and identify horizontal asymptotes for rational and transcendental functions."
      },

    {
      "id": "spine_mathematics_l4_finding_eigenvectors",
      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_eigenvalues_and_eigenvectors",
      "content": {
        "title": "Finding Eigenvectors",
        "definition": "For each eigenvalue λ, solve (A − λI)v = 0 to obtain eigenvectors in the null space of A − λI.",
        "summary": "Eigenspace for λ is the set of all eigenvectors plus zero, forming a subspace."
      },

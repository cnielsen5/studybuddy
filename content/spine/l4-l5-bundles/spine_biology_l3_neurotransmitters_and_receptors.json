      "content": {
        "title": "Metabotropic Receptors",
        "definition": "G protein-coupled neurotransmitter receptors that initiate intracellular signaling cascades producing slower, modulatory changes in postsynaptic excitability.",
        "summary": "Metabotropic receptors amplify signals through second messengers. They modulate ion channel activity and gene expression on slower timescales than ionotropic receptors."
      },

    {
      "id": "spine_biology_l4_excitatory_inhibitory_neurotransmitters",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_neurotransmitters_and_receptors",
      "content": {
        "title": "Excitatory vs Inhibitory Neurotransmitters",
        "definition": "Classification by postsynaptic effect: excitatory transmitters depolarize toward threshold (glutamate, ACh at NMJ), inhibitory transmitters hyperpolarize or shunt (GABA, glycine).",
        "summary": "Balance of EPSPs and IPSPs determines neuronal output. GABA is the major CNS inhibitory transmitter."
      },

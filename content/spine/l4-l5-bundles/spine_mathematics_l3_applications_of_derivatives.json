      "content": {
        "title": "Optimization Problems",
        "definition": "Applied problems that maximize or minimize a quantity subject to constraints by identifying a differentiable objective function, finding critical points on a valid domain, and verifying the extremum.",
        "summary": "Optimization translates word problems into calculus: define variables, write the function to optimize, differentiate, and interpret results in context."

    {
      "id": "spine_mathematics_l4_critical_points_first_derivative",
      "resolution_level": 4,
      "anchor_concept_id": "spine_mathematics_l3_applications_of_derivatives",
      "content": {
        "title": "Critical Points and First Derivative Test",
        "definition": "Critical points occur where f′(x) = 0 or f′ is undefined; the first derivative test classifies them as local maxima or minima by sign changes of f′.",
        "summary": "Finding where the rate of change vanishes locates candidate extrema. Sign analysis of f′ on intervals determines increasing and decreasing behavior."
      },

      "id": "spine_biology_l4_homeostatic_disruption_disease",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_homeostasis_and_feedback",
      "content": {
        "title": "Homeostatic Disruption in Disease",
        "definition": "Pathological states arising when feedback control fails, set points shift, or compensatory mechanisms become overwhelmed or maladaptive.",
        "summary": "Disease can reflect sensor failure, effector failure, or inappropriate gain in feedback loops. Understanding disruption guides diagnosis and treatment."
      },

      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_homeostasis_and_feedback",
      "content": {
        "title": "Positive Feedback Loops",
        "definition": "Amplifying circuits in which an initial change promotes further change in the same direction until an endpoint event terminates the cycle.",
        "summary": "Positive feedback drives events requiring rapid completion such as childbirth (oxytocin) and blood clotting cascade amplification."
      },

    {
      "id": "spine_biology_l4_set_point_compensation",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_homeostasis_and_feedback",
      "content": {
        "title": "Set Point and Compensatory Mechanisms",
        "definition": "Defended physiological targets around which variables oscillate, with secondary compensatory responses attempting to restore balance when primary control fails.",
        "summary": "Compensation may fully correct (respiratory alkalosis compensation) or partially restore (cardiac remodeling in heart failure). Chronic compensation can become maladaptive."
      },

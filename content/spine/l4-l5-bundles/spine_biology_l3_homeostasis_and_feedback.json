      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_homeostasis_and_feedback",
      "content": {
        "title": "Negative Feedback Loops",
        "definition": "Regulatory circuits in which a change in a controlled variable triggers responses that oppose the initial deviation, returning the system toward a set point.",
        "summary": "Negative feedback stabilizes temperature, blood pressure, and hormone levels. Sensors, integrators, and effectors form closed-loop control."
      },

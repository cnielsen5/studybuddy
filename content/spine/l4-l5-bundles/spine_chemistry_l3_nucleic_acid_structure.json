    {
      "id": "spine_chemistry_l4_dna_melting_temperature",
      "resolution_level": 4,
      "anchor_concept_id": "spine_chemistry_l3_nucleic_acid_structure",
      "content": {
        "title": "DNA Melting Temperature and Stability",
        "definition": "The temperature at which half of the base pairs in a double-stranded DNA helix are disrupted, influenced by GC content, strand length, and ionic strength.",
        "summary": "Higher GC content increases helix stability and melting temperature because G–C pairs form three hydrogen bonds. Tm is central to PCR annealing and hybridization assays."
      },

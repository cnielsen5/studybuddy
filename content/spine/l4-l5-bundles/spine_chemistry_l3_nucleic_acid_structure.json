    {
      "id": "spine_chemistry_l5_base_mismatch_stability",
      "resolution_level": 5,
      "anchor_concept_id": "spine_chemistry_l3_nucleic_acid_structure",
      "content": {
        "title": "Mismatch Effects on Helix Stability",
        "definition": "Reduction in double-helix stability caused by non-Watson–Crick base pairing or bulges, including wobble pairs such as G–U, which destabilize the helix relative to perfect complementarity.",
        "summary": "Mismatches lower melting temperature and can trigger repair or translational ambiguity. Wobble pairing in RNA accepts G–U at the third codon position without changing the encoded amino acid."
      },
      "knowledge_graph": {
        "knowledge_area": "Physical Sciences",

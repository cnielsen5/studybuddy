    {
      "id": "spine_chemistry_l4_dna_grooves",
      "resolution_level": 4,
      "anchor_concept_id": "spine_chemistry_l3_nucleic_acid_structure",
      "content": {
        "title": "Major and Minor Grooves",
        "definition": "Shallow indentations on the surface of the DNA double helix created by the geometry of base-pair stacking, providing sites for sequence-specific protein and small-molecule binding.",
        "summary": "The major groove exposes distinct hydrogen-bond patterns for each base pair, enabling proteins to read DNA sequence. The minor groove is narrower but also participates in molecular recognition."
      },

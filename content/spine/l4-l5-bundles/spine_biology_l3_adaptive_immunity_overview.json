    {
      "id": "spine_biology_l4_lymphocyte_activation",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_adaptive_immunity_overview",
      "content": {
        "title": "Lymphocyte Activation Requirements",
        "definition": "Dual-signal requirement for full lymphocyte activation involving antigen receptor engagement plus co-stimulatory signals, with MHC molecules presenting processed antigen to T cells.",
        "summary": "T cells require MHC-presented peptide antigen and co-stimulation to avoid anergy. B cells can be activated by T-dependent or T-independent antigens with distinct outcomes."
      },

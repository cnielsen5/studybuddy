      "resolution_level": 5,
      "anchor_concept_id": "spine_biology_l3_adaptive_immunity_overview",
      "content": {
        "title": "Germinal Center Affinity Maturation",
        "definition": "Somatic hypermutation and selection in germinal centers producing high-affinity antibody variants on memory B cells and plasma cells.",
        "summary": "B cells compete for antigen and T follicular helper signals in germinal centers. Selected clones expand; others undergo apoptosis."
      },

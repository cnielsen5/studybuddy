    {
      "id": "spine_biology_l4_primary_secondary_response",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_adaptive_immunity_overview",
      "content": {
        "title": "Primary vs Secondary Immune Response",
        "definition": "The slower, lower-magnitude initial adaptive response to a novel antigen compared with the faster, stronger recall response upon re-exposure due to expanded memory lymphocyte populations.",
        "summary": "Primary responses generate effector cells and memory over days to weeks. Secondary responses mobilize memory B and T cells rapidly, producing higher antibody titers and faster pathogen clearance."
      },
      "knowledge_graph": {

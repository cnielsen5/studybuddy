    {
      "id": "spine_biology_l5_secondary_response_igm_igg_switch",
      "resolution_level": 5,
      "anchor_concept_id": "spine_biology_l3_adaptive_immunity_overview",
      "content": {
        "title": "Secondary Response IgM-to-IgG Switch",
        "definition": "Accelerated class-switch recombination during secondary responses producing predominantly high-affinity IgG with minimal IgM in recall responses.",

    {
      "id": "spine_biology_l4_clonal_selection",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_adaptive_immunity_overview",
      "content": {
        "title": "Clonal Selection and Lymphocyte Expansion",
        "definition": "Process by which antigen binding to a lymphocyte receptor selects that clone for proliferation and differentiation, producing effector cells and memory cells specific to the encountered antigen.",
        "summary": "Clonal selection explains antigen specificity and memory in adaptive immunity. Each lymphocyte recognizes one epitope; antigen encounter drives clonal expansion."
      },
      "knowledge_graph": {

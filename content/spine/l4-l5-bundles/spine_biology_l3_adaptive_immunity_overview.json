    {
      "id": "spine_biology_l4_humoral_vs_cell_mediated",
      "resolution_level": 4,
      "anchor_concept_id": "spine_biology_l3_adaptive_immunity_overview",
      "content": {
        "title": "Humoral and Cell-Mediated Immunity",
        "definition": "Two adaptive arms in which B lymphocytes produce circulating antibodies (humoral) and T lymphocytes directly kill infected cells or coordinate responses (cell-mediated).",
        "summary": "Humoral immunity targets extracellular pathogens via antibody neutralization and opsonization. Cell-mediated immunity eliminates intracellular pathogens through cytotoxic T cells and helper T cell coordination."
      },
